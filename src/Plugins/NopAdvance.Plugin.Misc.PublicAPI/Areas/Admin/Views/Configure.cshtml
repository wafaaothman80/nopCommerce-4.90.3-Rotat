@model ConfigurationModel

@{
    Layout = generichelper.GetPluginConfigureLayout();
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName(SiteMapDefaults.CONFIGURE_MENU_SYSTEM_NAME);

    ViewBag.SystemName = PluginDefaults.SYSTEM_NAME;
    ViewBag.LicenseStatus = Model.LicenseStatus;
}

<script>
    $(document).ready(function () {
        $("#@Html.IdFor(model => model.Enabled)").click(toggleEnableAPI);

        toggleEnableAPI();
    });

    function toggleEnableAPI() {
        if ($('#@Html.IdFor(model => model.Enabled)').is(':checked')) {
            $('#pnlEnableSwagger').showElement();
            $('#pnlIsDevelopment').showElement();
            $('#pnlSecretKey').showElement();
            $('#pnlSecurityAlgorithmTypeId').showElement();
            $('#pnlAccessTokenExpiration').showElement();
            $('#pnlRefreshTokenExpiration').showElement();
            $('#pnlEnableDebugging').showElement();
        } else {
            $('#pnlEnableSwagger').hideElement();
            $('#pnlIsDevelopment').hideElement();
            $('#pnlSecretKey').hideElement();
            $('#pnlSecurityAlgorithmTypeId').hideElement();
            $('#pnlAccessTokenExpiration').hideElement();
            $('#pnlRefreshTokenExpiration').hideElement();
            $('#pnlEnableDebugging').hideElement();
        }
    }
</script>

@await Component.InvokeAsync("StoreScopeConfiguration")
<form asp-controller="@SiteMapDefaults.ADMIN_CONFIGURE_CONTROLLER_NAME" asp-action="@SiteMapDefaults.CONFIGURE_ACTION_NAME" method="post">
    <div class="cards-group">
        <div class="card card-default">
            <div class="card-body">
                <div class="form-group row">
                    <div class="col-md-3">
                        <nop-override-store-checkbox asp-for="Enabled_OverrideForStore" asp-input="Enabled" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                        <nop-label asp-for="Enabled" />
                    </div>
                    <div class="col-md-9">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="d-flex">
                                    <div class="api-enabled">
                                        <nop-editor asp-for="Enabled" />
                                        <span asp-validation-for="Enabled"></span>
                                    </div>
                                    <div class="callout bg-gray-light no-margin">
                                        @T(LocaleResourceDefaults.CONFIGURE_RESTART_NOTE)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <nop-nested-setting asp-for="Enabled">
                    <div class="form-group row" id="pnlEnableSwagger">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="EnableSwagger_OverrideForStore" asp-input="EnableSwagger" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="EnableSwagger" />
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="d-flex">
                                        <div class="api-enabled">
                                            <nop-editor asp-for="EnableSwagger" />
                                            <span asp-validation-for="EnableSwagger"></span>
                                        </div>
                                        <div class="callout bg-gray-light no-margin">
                                            @T(LocaleResourceDefaults.CONFIGURE_RESTART_NOTE)
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row" id="pnlIsDevelopment">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="IsDevelopment_OverrideForStore" asp-input="IsDevelopment" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="IsDevelopment" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="IsDevelopment" />
                            <span asp-validation-for="IsDevelopment"></span>
                        </div>
                    </div>
                    <div class="form-group row" id="pnlSecretKey">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="SecretKey_OverrideForStore" asp-input="SecretKey" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="SecretKey" />
                        </div>
                        <div class="col-md-9">
                            <div class="input-group input-group-short">
                                <nop-editor asp-for="SecretKey" />
                                <span class="input-group-append">
                                    <button type="submit" name="changesecuritykey" id="changesecuritykey" class="btn btn-info">
                                        @T("Admin.Common.Change")
                                    </button>
                                    <nop-action-confirmation asp-button-id="changesecuritykey" />
                                </span>
                            </div>
                            <span asp-validation-for="SecretKey"></span>
                        </div>
                    </div>
                    <div class="form-group row" id="pnlSecurityAlgorithmTypeId">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="SecurityAlgorithmTypeId_OverrideForStore" asp-input="SecurityAlgorithmTypeId" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="SecurityAlgorithmTypeId" />
                        </div>
                        <div class="col-md-9">
                            <nop-select asp-for="SecurityAlgorithmTypeId" asp-items="Model.AvailableSecurityAlgorithmTypes" />
                            <span asp-validation-for="SecurityAlgorithmTypeId"></span>
                        </div>
                    </div>
                    <div class="form-group row" id="pnlAccessTokenExpiration">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="AccessTokenExpiration_OverrideForStore" asp-input="AccessTokenExpiration" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="AccessTokenExpiration" />
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-4">
                                    <nop-editor asp-for="AccessTokenExpiration" />
                                    <span asp-validation-for="AccessTokenExpiration"></span>
                                </div>
                                <div class="col-md-8">
                                    <nop-select asp-for="AccessTokenExpirationDurationId" asp-items="Model.AvailableAccessTokenExpirationDurations" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row" id="pnlRefreshTokenExpiration">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="RefreshTokenExpiration_OverrideForStore" asp-input="RefreshTokenExpiration" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="RefreshTokenExpiration" />
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-4">
                                    <nop-editor asp-for="RefreshTokenExpiration" />
                                    <span asp-validation-for="RefreshTokenExpiration"></span>
                                </div>
                                <div class="col-md-8">
                                    <nop-select asp-for="RefreshTokenExpirationDurationId" asp-items="Model.AvailableRefreshTokenExpirationDurations" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row" id="pnlEnableDebugging">
                        <div class="col-md-3">
                            <nop-override-store-checkbox asp-for="EnableDebugging_OverrideForStore" asp-input="EnableDebugging" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                            <nop-label asp-for="EnableDebugging" />
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-4">
                                    <nop-editor asp-for="EnableDebugging" />
                                    <span asp-validation-for="EnableDebugging"></span>
                                </div>
                                <div class="col-md-8">
                                    @T("NopAdvance.Plugin.PublicAPI.Configure.Fields.EnableDebugging.Warning")
                                </div>
                            </div>
                        </div>
                    </div>
                </nop-nested-setting>
                <div class="form-group row">
                    <div class="col-md-9 offset-md-3">
                        <button type="submit" name="save" class="btn btn-primary">@T("Admin.Common.Save")</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
<style>
    .api-enabled {
        margin-right: 15px;
    }
</style>