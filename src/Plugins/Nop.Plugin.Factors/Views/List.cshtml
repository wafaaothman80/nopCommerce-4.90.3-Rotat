@model CODFactorsSearchModel
@using Nop.Plugin.Factors
@using Nop.Web.Framework.Models.DataTables

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = "COD Factors";
    NopHtml.SetActiveMenuItemSystemName("COD Factors");
}

<div class="content-header clearfix">
    <h1 class="float-left">
        COD Factors
    </h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default">
                    <div class="card-body">
                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-label asp-for="SearchCountryId" />
                            </div>
                            <div class="col-md-9">
                                <nop-select asp-for="SearchCountryId" asp-items="Model.AvailableCountries" />
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-9 offset-md-3">
                                <button type="button" id="search-codfactors" class="btn btn-primary btn-search">
                                    <i class="fas fa-search"></i>
                                    @T("Admin.Common.Search")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body">
                        <div id="codfactors-area">
                            @await Html.PartialAsync("Table", new DataTablesModel
                            {
                                Name = "codfactors-grid",
                                                        UrlRead = new DataUrl("List", "CODFactors", null),
                                                        SearchButtonId = "search-codfactors",
                                                        Length = Model.PageSize,
                                                        LengthMenu = Model.AvailablePageSizes,
                                                        Filters = new List<FilterParameter>
                                                        {
                                                        new FilterParameter(nameof(Model.SearchCountryId))
                                                        },
                                                        ColumnCollection = new List<ColumnProperty>
                                                        {
                                                        new ColumnProperty(nameof(CODFactorsModel.Id))
                                                        {
                                                        Title = "ID",
                                                        Width = "50",
                                                        Visible = false // Hide the ID column but keep it in the data
                                                        },
                                                        new ColumnProperty(nameof(CODFactorsModel.CountryName))
                                                        {
                                                        Title = T("Nop.Plugin.Factors.Fields.Country").Text,
                                                        Width = "150"
                                                        },
                                                        new ColumnProperty(nameof(CODFactorsModel.Name))
                                                        {
                                                        Title = T("Nop.Plugin.Factors.Fields.Name").Text,
                                                        Width = "150"
                                                        },
                                                        new ColumnProperty(nameof(CODFactorsModel.CODFactor))
                                                        {
                                                        Title = T("Nop.Plugin.Factors.Fields.CODFactor").Text,
                                                        Width = "100",
                                                        ClassName = NopColumnClassDefaults.CenterAll,
                                                        Render = new RenderCustom("renderFactorEdit")
                                                        },
                                                       
                                                        new ColumnProperty(nameof(CODFactorsModel.Id))
                                                        {
                                                        Title = T("Admin.Common.Actions").Text,
                                                        Width = "150",
                                                        ClassName = NopColumnClassDefaults.Button,
                                                        Render = new RenderCustom("renderFactorActions")
                                                        }
                                                        }
                                                        })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function renderFactorEdit(data, type, row, meta) {
        return `
            <div class="factor-edit-container" data-id="${row.Id}">
                <span class="factor-display">${row.CODFactor}</span>
                <div class="factor-edit-form" style="display: none;">
                    <input type="number" step="0.01" class="form-control form-control-sm factor-input" value="${row.CODFactor}" />
                    <div class="btn-group mt-1">
                        <button type="button" class="btn btn-success btn-sm factor-save">Save</button>
                        <button type="button" class="btn btn-secondary btn-sm factor-cancel">Cancel</button>
                    </div>
                </div>
            </div>
        `;
    }

    function renderFactorActions(data, type, row, meta) {
        return `
            <div class="btn-group">
                <button type="button" class="btn btn-default btn-sm edit-factor" data-id="${row.Id}">
                    <i class="fas fa-pencil-alt"></i> Edit Factor
                </button>
                <form class="d-inline" method="post" action="@Url.Action("Delete", "CODFactors")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="${row.Id}" />
                  
                </form>
            </div>
        `;
    }

    $(document).ready(function () {
        var token = $('input[name="__RequestVerificationToken"]').val();

        console.log('Document ready - Token found:', !!token);

        // Edit factor inline
        $(document).on('click', '.edit-factor', function () {
            var id = $(this).data('id');
            console.log('Edit clicked - ID:', id);

            var container = $(this).closest('tr').find('.factor-edit-container');
            container.find('.factor-display').hide();
            container.find('.factor-edit-form').show();
            container.find('.factor-input').focus().select();
        });

        // Cancel edit
        $(document).on('click', '.factor-cancel', function () {
            var container = $(this).closest('.factor-edit-container');
            var originalValue = container.find('.factor-display').text();
            container.find('.factor-input').val(originalValue);
            container.find('.factor-edit-form').hide();
            container.find('.factor-display').show();
        });

        // Save factor
        $(document).on('click', '.factor-save', function () {
            var container = $(this).closest('.factor-edit-container');
            var id = container.data('id');
            var newValue = parseFloat(container.find('.factor-input').val());
            var displaySpan = container.find('.factor-display');

            console.log('Save - ID:', id, 'Value:', newValue, 'Type of ID:', typeof id);

            // Validation
            if (!id || id <= 0) {
                alert('Error: Invalid record ID. Please refresh the page and try again.');
                return;
            }

            if (isNaN(newValue) ) {
                alert('Error: Please enter a valid positive number');
                container.find('.factor-input').focus().select();
                return;
            }

            var saveBtn = $(this);
            var originalText = saveBtn.text();
            saveBtn.text('Saving...').prop('disabled', true);

            // AJAX call to update the factor
            $.ajax({
                url: '@Url.Action("UpdateFactor", "CODFactors")',
                type: 'POST',
                data: {
                    id: id,
                    codFactor: newValue,
                    __RequestVerificationToken: token
                },
                dataType: 'json',
                success: function (response) {
                    console.log('AJAX Success Response:', response);
                    if (response.success) {
                        displaySpan.text(newValue);
                        container.find('.factor-edit-form').hide();
                        container.find('.factor-display').show();
                        alert('✓ Factor updated successfully');
                    } else {
                        alert('✗ ' + response.message);
                        // Revert to original value on error
                        container.find('.factor-input').val(displaySpan.text());
                    }
                },
                error: function (xhr, status, error) {
                    console.log('AJAX Error:', status, error);
                    alert('✗ Error updating factor: ' + error);
                    // Revert to original value on error
                    container.find('.factor-input').val(displaySpan.text());
                },
                complete: function () {
                    saveBtn.text(originalText).prop('disabled', false);
                }
            });
        });

        // Handle Enter key in input
        $(document).on('keypress', '.factor-input', function (e) {
            if (e.which === 13) {
                $(this).closest('.factor-edit-form').find('.factor-save').click();
            }
        });

        // Handle Escape key to cancel
        $(document).on('keydown', '.factor-input', function (e) {
            if (e.which === 27) {
                $(this).closest('.factor-edit-form').find('.factor-cancel').click();
            }
        });

        // Debug: Log DataTables data
        setTimeout(function() {
            var table = $('#codfactors-grid').DataTable();
            console.log('DataTables data:', table.data().toArray());
        }, 1000);
    });
</script>