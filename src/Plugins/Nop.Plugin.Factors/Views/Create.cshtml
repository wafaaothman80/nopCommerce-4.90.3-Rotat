@model Nop.Plugin.Factors.Models.CODFactorsModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = "Add New COD Factor";
}

<form asp-controller="CODFactors" asp-action="Create" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            Add New COD Factor
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List">Back to list</a>
            </small>
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                Save
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-save"></i>
                Save and Continue Editing
            </button>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="form-horizontal">
                <div class="cards-group">
                    <div class="card card-default">
                        <div class="card-body">
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="CountryID" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="CountryID" />
                                    <span asp-validation-for="CountryID"></span>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="Name" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="Name" />
                                    <span asp-validation-for="Name"></span>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="CODFactor" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="CODFactor" />
                                    <span asp-validation-for="CODFactor"></span>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="FactorID" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="FactorID" />
                                    <span asp-validation-for="FactorID"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>