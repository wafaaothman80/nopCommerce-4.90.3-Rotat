@model BrandsFactorsSearchModel
@using Nop.Web.Framework.Models.DataTables

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = "Brand Factors";
    NopHtml.SetActiveMenuItemSystemName("Brand Factors");
}

<div class="content-header clearfix">
    <h1 class="float-left">
        Brand Factors
    </h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default">
                    <div class="card-body">
                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-label asp-for="SearchBrandName" />
                            </div>
                            <div class="col-md-9">
                                <nop-select asp-for="SearchBrandName" asp-items="Model.AvailableBrandNames" />
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-9 offset-md-3">
                                <button type="button" id="search-Brandfactors" class="btn btn-primary btn-search">
                                    <i class="fas fa-search"></i>
                                    @T("Admin.Common.Search")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body">
                        <div id="Brandfactors-area">
                            @await Html.PartialAsync("Table", new DataTablesModel
                            {
                                Name = "Brandfactors-grid",
                                                        UrlRead = new DataUrl("List", "BrandFactors", null),
                                                        SearchButtonId = "search-Brandfactors",
                                                        Length = Model.PageSize,
                                                        LengthMenu = Model.AvailablePageSizes,
                                                        Filters = new List<FilterParameter>
                                                        {
                                                        new FilterParameter(nameof(Model.SearchBrandName))
                                                        },
                                                        ColumnCollection = new List<ColumnProperty>
                                                        {
                                                        new ColumnProperty(nameof(BrandsFactorsModel.Id))
                                                        {
                                                        Title = "ID",
                                                        Width = "50",
                                                        Visible = false
                                                        },
                                                        new ColumnProperty(nameof(BrandsFactorsModel.BrandID))
                                                        {
                                                        Title = T("Plugins.Factors.Fields.BrandID").Text,
                                                        Width = "80"
                                                        },
                                                        new ColumnProperty(nameof(BrandsFactorsModel.Name))
                                                        {
                                                        Title = T("Plugins.Factors.Fields.Name").Text,
                                                        Width = "200"
                                                        },
                                                        new ColumnProperty(nameof(BrandsFactorsModel.Factor))
                                                        {
                                                        Title = T("Plugins.Factors.Fields.Factor").Text,
                                                        Width = "100",
                                                        ClassName = NopColumnClassDefaults.CenterAll,
                                                        Render = new RenderCustom("renderFactorEdit")
                                                        },
                                                        new ColumnProperty(nameof(BrandsFactorsModel.Id))
                                                        {
                                                        Title = T("Admin.Common.Actions").Text,
                                                        Width = "100",
                                                        ClassName = NopColumnClassDefaults.Button,
                                                        Render = new RenderCustom("renderFactorActions")
                                                        }
                                                        }
                                                        })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function renderFactorEdit(data, type, row, meta) {
        return `
            <div class="factor-edit-container" data-id="${row.Id}">
                <span class="factor-display">${row.Factor}</span>
                <div class="factor-edit-form" style="display: none;">
                    <input type="number" step="0.01" class="form-control form-control-sm factor-input" value="${row.Factor}" />
                    <div class="btn-group mt-1">
                        <button type="button" class="btn btn-success btn-sm factor-save">Save</button>
                        <button type="button" class="btn btn-secondary btn-sm factor-cancel">Cancel</button>
                    </div>
                </div>
            </div>
        `;
    }

    function renderFactorActions(data, type, row, meta) {
        return `
            <div class="btn-group">
                <button type="button" class="btn btn-default btn-sm edit-factor" data-id="${row.Id}">
                    <i class="fas fa-pencil-alt"></i> Edit Factor
                </button>
            </div>
        `;
    }

    $(document).ready(function () {
        var token = $('input[name="__RequestVerificationToken"]').val();

        // Edit factor inline
        $(document).on('click', '.edit-factor', function () {
            var id = $(this).data('id');
            var container = $(`[data-id="${id}"]`);

            container.find('.factor-display').hide();
            container.find('.factor-edit-form').show();
            container.find('.factor-input').focus().select();
        });

        // Cancel edit
        $(document).on('click', '.factor-cancel', function () {
            var container = $(this).closest('.factor-edit-container');
            var originalValue = container.find('.factor-display').text();
            container.find('.factor-input').val(originalValue);
            container.find('.factor-edit-form').hide();
            container.find('.factor-display').show();
        });

        // Save factor
        $(document).on('click', '.factor-save', function () {
            var container = $(this).closest('.factor-edit-container');
            var id = container.data('id');
            var newValue = parseFloat(container.find('.factor-input').val());
            var displaySpan = container.find('.factor-display');

            if (isNaN(newValue) ) {
                alert('Please enter a valid positive number');
                return;
            }

            var saveBtn = $(this);
            var originalText = saveBtn.text();
            saveBtn.text('Saving...').prop('disabled', true);

            $.ajax({
                url: '@Url.Action("UpdateFactor", "BrandFactors")',
                type: 'POST',
                data: {
                    id: id,
                    factor: newValue,
                    __RequestVerificationToken: token
                },
                success: function (response) {
                    if (response.success) {
                        displaySpan.text(newValue);
                        container.find('.factor-edit-form').hide();
                        container.find('.factor-display').show();
                        showAlert('Factor updated successfully', 'success');
                    } else {
                        showAlert(response.message, 'error');
                    }
                },
                error: function () {
                    showAlert('Error updating factor', 'error');
                },
                complete: function () {
                    saveBtn.text(originalText).prop('disabled', false);
                }
            });
        });

        

        function showAlert(message, type) {
            // Use NopCommerce notification system or simple alert
            alert(message);
        }
    });
</script>