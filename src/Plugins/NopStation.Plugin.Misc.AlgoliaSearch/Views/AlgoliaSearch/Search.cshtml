@model SearchModel
@using Nop.Web.Extensions
@using NopStation.Plugin.Misc.AlgoliaSearch.Infrastructure

@{
    Layout = "_ColumnsTwo";

    NopHtml.AddTitleParts(T("PageTitle.Search").Text);
    NopHtml.AppendPageCssClassParts("html-search-page");

    var stockQtySortValue = (int)AlgoliaSortingEnum.StockQty;
}

@section left
{
    @await Html.PartialAsync(
    "~/Plugins/NopStation.Plugin.Misc.AlgoliaSearch/Views/AlgoliaSearch/_AlgoliaFilters.cshtml",
        Model.PagingFilteringContext
    )
}

<div class="page search-page">
    <div class="page-title">
        <h1>@T("Search")</h1>
    </div>

    <div class="page-body">
        @if (Model.Products.Count == 0)
        {
            var q = Model.q;
            var quoteUrl = Url.Content("~/QuoteCart");

            <div class="no-result no-result-quote">
                <div class="no-result-title">
                    No results for <strong>@q</strong>
                </div>
                <div class="no-result-text">
                    Can't find your product? Submit a quote and we will help you find it.
                </div>
                <div style="margin-top:10px;">
                    <a class="submit-quote-btn" href="@quoteUrl">Submit Quote</a>
                </div>
            </div>
        }

        @if (Model.Products.Count > 0)
        {
            <div class="algolia-selectors-row">
                <div class="algolia-inline-filters">
                    <label for="onlyInStockToggle" class="stock-filter-label">
                        <input type="checkbox"
                               id="onlyInStockToggle"
                               @(Model.PagingFilteringContext.OnlyInStock ? "checked" : "") />
                        <span>Only in-stock items</span>
                    </label>

                    <label for="discountOnlyToggle" class="stock-filter-label">
                        <input type="checkbox"
                               id="discountOnlyToggle"
                               @(Model.PagingFilteringContext.DiscountOnly ? "checked" : "") />
                        <span>Discount only</span>
                    </label>
                </div>

                <div class="algolia-selectors-wrap">
                    @await Html.PartialAsync(
                    "~/Plugins/NopStation.Plugin.Misc.AlgoliaSearch/Views/AlgoliaSearch/_AlgoliaSelectors.cshtml",
                                Model.PagingFilteringContext
                                )
            </div>
        </div>
                }

        @if (Model.Products.Count > 0)
        {
            <div class="@(Model.PagingFilteringContext.ViewMode == "list" ? "product-list" : "product-grid")">
                <div class="item-grid">
                    @foreach (var product in Model.Products)
                    {
                        <div class="item-box">
                            @await Html.PartialAsync("_ProductBox", product)
                        </div>
                    }
                </div>
            </div>
        }

        @{
            var pager = Html.Pager(Model.PagingFilteringContext)
            .QueryParam("pagenumber")
            .RenderEmptyParameters(true);
        }

        @if (!await pager.IsEmpty())
        {
            <div class="pager">
                @pager
            </div>
        }

        @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.ProductSearchPageAfterResults })
    </div>
</div>

<style>
    .submit-quote-btn {
        display: inline-block;
        padding: 10px 16px;
        background-color: #1f278a;
        color: #fff !important;
        border-radius: 4px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
    }

        .submit-quote-btn:hover {
            background-color: #0e164a;
            color: #fff !important;
        }
    .algolia-inline-filters {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }

        .algolia-inline-filters input[type="checkbox"],
        #onlyInStockToggle,
        #discountOnlyToggle {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            min-width: 18px;
            border: 2px solid #1f278a;
            border-radius: 0;
            background: #fff;
            display: inline-block;
            position: relative;
            cursor: pointer;
            vertical-align: middle;
        }

            .algolia-inline-filters input[type="checkbox"]:checked,
            #onlyInStockToggle:checked,
            #discountOnlyToggle:checked {
                background: #1f278a;
            }

                .algolia-inline-filters input[type="checkbox"]:checked::after,
                #onlyInStockToggle:checked::after,
                #discountOnlyToggle:checked::after {
                    content: "";
                    position: absolute;
                    left: 4px;
                    top: 0px;
                    width: 5px;
                    height: 10px;
                    border: solid #fff;
                    border-width: 0 2px 2px 0;
                    transform: rotate(45deg);
                }

    .algolia-selectors-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }

    .algolia-selectors-wrap {
        flex: 1 1 auto;
        min-width: 320px;
    }

    .stock-filter-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        margin: 0;
        white-space: nowrap;
        font-size: 14px;
        font-weight: 500;
    }

        .stock-filter-label input[type="checkbox"] {
            margin: 0;
        }

    @@media (max-width: 991px) {
        .algolia-selectors-row {
            align-items: flex-start;
        }

        .algolia-inline-filters {
            width: 100%;
        }
    }
</style>

<script>
    $(document).ready(function () {

        var stockOverlayTimer = null;
        var pendingQuoteAction = null;

        function ensureStockOverlay() {
            if (!$('#stock-overlay-style').length) {
                $('head').append(`
                    <style id="stock-overlay-style">
                        #stock-overlay-backdrop{
                            position:fixed;
                            top:0;
                            left:0;
                            width:100%;
                            height:100%;
                            background:rgba(0,0,0,0.18);
                            z-index:99998;
                            display:none;
                        }

                        #stock-overlay-message{
                            position:fixed;
                            top:50%;
                            left:50%;
                            transform:translate(-50%, -50%);
                            background:#1f278a;
                            color:#fff;
                            padding:30px 40px;
                            min-width:320px;
                            max-width:900px;
                            width:80%;
                            text-align:center;
                            font-size:28px;
                            font-weight:bold;
                            border-radius:4px;
                            z-index:99999;
                            display:none;
                            box-shadow:0 10px 30px rgba(0,0,0,0.25);
                        }

                        #stock-overlay-message .stock-popup-text{
                            line-height:1.5;
                            margin-bottom:20px;
                        }

                        #stock-overlay-message .stock-popup-buttons{
                            display:flex;
                            justify-content:center;
                            gap:18px;
                            flex-wrap:wrap;
                        }

                        #stock-overlay-message .stock-popup-btn{
                            min-width:105px;
                            padding:12px 26px;
                            border:none;
                            border-radius:4px;
                            font-size:18px;
                            font-weight:bold;
                            cursor:pointer;
                        }

                        #stock-overlay-message .stock-popup-btn.yes-btn{
                            background:#f5a623;
                            color:#000;
                        }

                        #stock-overlay-message .stock-popup-btn.no-btn{
                            background:#f2f2f2;
                            color:#111;
                        }

                        @@media (max-width: 768px){
                            #stock-overlay-message{
                                font-size:20px;
                                padding:20px;
                                width:92%;
                            }

                            #stock-overlay-message .stock-popup-btn{
                                font-size:16px;
                                min-width:90px;
                                padding:10px 18px;
                            }
                        }
                    </style>
                `);
            }

            if (!$('#stock-overlay-backdrop').length) {
                $('body').append('<div id="stock-overlay-backdrop"></div>');
            }

            if (!$('#stock-overlay-message').length) {
                $('body').append('<div id="stock-overlay-message"></div>');
            }
        }

        function showSimpleStockOverlay(message) {
            ensureStockOverlay();
            clearTimeout(stockOverlayTimer);
            pendingQuoteAction = null;

            $('#stock-overlay-message').html('<div class="stock-popup-text">' + message + '</div>');
            $('#stock-overlay-backdrop').stop(true, true).fadeIn(150);
            $('#stock-overlay-message').stop(true, true).fadeIn(150);

            stockOverlayTimer = setTimeout(function () {
                hideStockOverlay();
            }, 2200);
        }

        function showConfirmStockOverlay(messageHtml, yesCallback, noCallback) {
            ensureStockOverlay();
            clearTimeout(stockOverlayTimer);

            pendingQuoteAction = {
                yes: yesCallback,
                no: noCallback
            };

            var html =
                '<div class="stock-popup-text">' + messageHtml + '</div>' +
                '<div class="stock-popup-buttons">' +
                    '<button type="button" class="stock-popup-btn yes-btn" id="stock-popup-yes">Yes</button>' +
                    '<button type="button" class="stock-popup-btn no-btn" id="stock-popup-no">No</button>' +
                '</div>';

            $('#stock-overlay-message').html(html);
            $('#stock-overlay-backdrop').stop(true, true).fadeIn(150);
            $('#stock-overlay-message').stop(true, true).fadeIn(150);
        }

        function hideStockOverlay() {
            clearTimeout(stockOverlayTimer);
            $('#stock-overlay-backdrop').stop(true, true).fadeOut(150);
            $('#stock-overlay-message').stop(true, true).fadeOut(150, function () {
                $('#stock-overlay-message').html('');
            });
        }

        function getLangPrefix() {
            var firstSeg = (location.pathname.split('/')[1] || '').toLowerCase();
            return (firstSeg.length === 2 || firstSeg === 'en' || firstSeg === 'ar' || firstSeg === 'fr')
                ? '/' + firstSeg + '/'
                : '/';
        }

        function getProductItemFromInput($input) {
            var $productItem = $input.closest('.product-item');

            if (!$productItem.length) {
                $productItem = $input.closest('.item-box').find('.product-item').first();
            }

            if (!$productItem.length) {
                $productItem = $input.closest('.item-box');
            }

            return $productItem;
        }

        function getProductItemFromButton($button) {
            var $productItem = $button.closest('.product-item');

            if (!$productItem.length) {
                $productItem = $button.closest('.item-box').find('.product-item').first();
            }

            if (!$productItem.length) {
                $productItem = $button.closest('.item-box');
            }

            return $productItem;
        }

        function getInputFromButton($button) {
            var $productItem = getProductItemFromButton($button);
            var $input = $productItem.find('.productQuantityTextBox').first();

            if (!$input.length) {
                $input = $button.closest('.item-box').find('.productQuantityTextBox').first();
            }

            return $input;
        }

        function getProductIdFromInput($input) {
            var $productItem = getProductItemFromInput($input);
            return parseInt($productItem.attr('data-productid'), 10) || 0;
        }

        function getStockFromItem($input) {
            var $productItem = getProductItemFromInput($input);

            var stockText = $.trim($productItem.find('.blockstok').first().text());
            if (!stockText) {
                stockText = $.trim($productItem.find('.description.gram.stock').text());
            }

            if (!stockText) return 0;

            stockText = stockText.toLowerCase();

            if (stockText.indexOf('out of stock') !== -1) {
                return 0;
            }

            var match = stockText.match(/(\d+)/);
            return match ? parseInt(match[1], 10) : 0;
        }

        function addToQuoteCartOnce(productId, qty) {
            return new Promise(function (resolve, reject) {
                var langPrefix = getLangPrefix();

                $.ajax({
                    type: "GET",
                    url: langPrefix + "AddQuote",
                    data: {
                        productId: productId,
                        quantity: qty,
                        attributeXml: ''
                    },
                    success: function (response) {
                        resolve(response);
                    },
                    error: function (xhr) {
                        reject(xhr);
                    }
                });
            });
        }

        function clickNormalCartButton($button, $input, stockQty) {
            return new Promise(function (resolve, reject) {
                try {
                    if (!$button || !$button.length) {
                        reject('Cart button not found');
                        return;
                    }

                    $input.val(stockQty);

                    $button.data('stock-script-bypass', true);

                    setTimeout(function () {
                        try {
                            $button[0].click();
                            resolve(true);
                        } catch (e) {
                            reject(e);
                        } finally {
                            setTimeout(function () {
                                $button.data('stock-script-bypass', false);
                            }, 300);
                        }
                    }, 80);

                } catch (e) {
                    reject(e);
                }
            });
        }

        function updateQuoteCounter(delta) {
            var $q = $('#qcartqty');
            if (!$q.length) return;

            var current = parseInt($.trim($q.text()), 10);
            if (isNaN(current)) current = 0;

            $q.text(current + delta);
        }

        async function processOverStock($button, $input, requestedQty, stockQty, productId) {
            var overQty = requestedQty - stockQty;

            $input.data('stock-script-lock', true);
            $input.val(stockQty);

            try {
                if (productId > 0 && stockQty > 0) {
                    await clickNormalCartButton($button, $input, stockQty);
                }

                if (productId > 0 && overQty > 0) {
                    await addToQuoteCartOnce(productId, overQty);
                    updateQuoteCounter(overQty);
                }

                showSimpleStockOverlay(
                    'Added ' + stockQty + ' to Cart and ' + overQty + ' to Quote Cart.'
                );
            } catch (e) {
                console.error('Split order failed:', e);
                showSimpleStockOverlay('Could not complete the request. Check console/network.');
            } finally {
                setTimeout(function () {
                    $input.data('stock-script-lock', false);
                }, 1200);
            }
        }

        function handleAddToCartClick($button, e) {
            if ($button.data('stock-script-bypass') === true) {
                return true;
            }

            var $input = getInputFromButton($button);

            if (!$input.length) {
                e.preventDefault();
                e.stopImmediatePropagation();
                showSimpleStockOverlay('Quantity textbox not found.');
                return false;
            }

            if ($input.data('stock-script-lock') === true) {
                e.preventDefault();
                e.stopImmediatePropagation();
                return false;
            }

            var rawValue = $.trim($input.val());
            var requestedQty = parseInt(rawValue, 10);
            var stockQty = getStockFromItem($input);
            var productId = getProductIdFromInput($input);

            if (rawValue === '' || isNaN(requestedQty)) {
                requestedQty = 1;
                $input.val(1);
            }

            if (requestedQty <= 0) {
                e.preventDefault();
                e.stopImmediatePropagation();
                $input.val(1);
                showSimpleStockOverlay('Minimum quantity 1 to make order.');
                return false;
            }

            if (stockQty <= 0) {
                e.preventDefault();
                e.stopImmediatePropagation();
                $input.val(1);
                showSimpleStockOverlay('This item is out of stock.');
                return false;
            }

            if (requestedQty > stockQty) {
                e.preventDefault();
                e.stopImmediatePropagation();

                var overQty = requestedQty - stockQty;

                showConfirmStockOverlay(
                    'Available stock is ' + stockQty + '. You requested ' + requestedQty + '.<br>Add ' + stockQty + ' to Cart and remaining ' + overQty + ' to Quote Cart?',
                    async function () {
                        hideStockOverlay();
                        await processOverStock($button, $input, requestedQty, stockQty, productId);
                    },
                    function () {
                        hideStockOverlay();
                        $input.val(stockQty);
                    }
                );

                return false;
            }

            $input.val(requestedQty);
            return true;
        }

        $(document).on('click', '#stock-popup-yes', function () {
            if (pendingQuoteAction && typeof pendingQuoteAction.yes === 'function') {
                pendingQuoteAction.yes();
            }
        });

        $(document).on('click', '#stock-popup-no', function () {
            if (pendingQuoteAction && typeof pendingQuoteAction.no === 'function') {
                pendingQuoteAction.no();
            }
        });

        $(document).on('click', '.product-box-add-to-cart-button.nopAjaxCartProductListAddToCartButton', function (e) {
            return handleAddToCartClick($(this), e);
        });

    });
</script>
<script>
    (function () {
        var stockCheckbox = document.getElementById("onlyInStockToggle");
        var discountCheckbox = document.getElementById("discountOnlyToggle");

        function applyAlgoliaToggles() {
            var url = new URL(window.location.href);
            var currentOrderBy = url.searchParams.get("orderby");

            if (stockCheckbox && stockCheckbox.checked) {
                url.searchParams.set("OnlyInStock", "true");

                // keep your existing stock sorting behavior
                if (!currentOrderBy || currentOrderBy === "0") {
                    url.searchParams.set("orderby", "99");
                }
            } else {
                url.searchParams.delete("OnlyInStock");

                // remove the forced stock sort only if it was set by this toggle
                if (currentOrderBy === "99") {
                    url.searchParams.delete("orderby");
                }
            }

            if (discountCheckbox && discountCheckbox.checked) {
                url.searchParams.set("DiscountOnly", "true");
            } else {
                url.searchParams.delete("DiscountOnly");
            }

            url.searchParams.delete("pageNumber");
            url.searchParams.delete("pagenumber");

            window.location.href = url.toString();
        }

        if (stockCheckbox) {
            stockCheckbox.addEventListener("change", applyAlgoliaToggles);
        }

        if (discountCheckbox) {
            discountCheckbox.addEventListener("change", applyAlgoliaToggles);
        }
    })();
</script>