<div class="search-container">
    <div class="search-tabs-container">
        <ul class="search-tabs">
            <li>
                <a href="#search-by-item" class="search-tab active" data-tab="item">
                    @T("Search by item")
                    <img alt="ROTAT" src="https://rotat.com/Themes/Prisma/Content/img/searchico.png">
                </a>
            </li>
            <li class="gray-blue">/</li>
            <li>
                <a href="#search-by-dimensions" class="search-tab" data-tab="dimension">
                    @T("Search by dimensions")
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="m14.293 5.293 1.5 1.5m-4.5 1.5 1.5 1.5m-4.5 1.5 1.5 1.5m-4.5 1.5 1.5 1.5m-4.434 1.566 3.868 3.868c.198.198.297.297.411.334a.5.5 0 0 0 .31 0c.114-.037.213-.136.41-.334L21.229 7.36c.197-.198.296-.297.333-.412a.5.5 0 0 0 0-.309c-.037-.114-.136-.213-.334-.41l-3.868-3.87c-.198-.197-.297-.296-.412-.334a.5.5 0 0 0-.309 0c-.114.038-.213.137-.41.335L2.357 16.227c-.197.198-.296.297-.334.411a.5.5 0 0 0 0 .31c.038.114.137.213.335.41Z"></path></svg>
                </a>
            </li>
        </ul>
    </div>
    <style>
        #small-searchterms::placeholder {
            color: #000 !important;
            opacity: 1 !important;
            font-size: 15px;
            line-height: 21px;font-weight:normal;text-transform:capitalize;
        }
        input#small-searchterms {
    
            padding-top: 0;
        }
    </style>
    <!-- Search by Item -->
    <form asp-route="ProductSearch" method="get" id="item-search-form" class="search-form active" data-form="item">
        <div class="search-input-group">
            <input type="text" class="search-box-text" id="small-searchterms" title="" autocomplete="off" name="q"
                   placeholder="" aria-label="@T("Search.SearchBox.Text.Label")" title="" />
            @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.SearchBoxBeforeSearchButton })
            <button type="submit" class="button-1 search-box-button">@T("Search.Button")</button>
        </div>
    </form>

    <!-- Search by Dimensions -->
    <form method="get" id="dimension-search-form" class="search-form" data-form="dimension" style="display:none"
          action="@Url.Action("Range", "AlgoliaRangeSearch")">

        <div id="dimension-messages"></div>
        <input type="hidden" id="dimension-search-query" name="q" value="" />

        <div class="dimension-inputs">
            <div class="dimension-field">
                <label>
                    @T("Inner Diameter (d)")</label>
                    <div class="dimension-range-inputs">
                        <input type="number" id="inner-min" class="dimension-input" placeholder="From" step="0.001" min="0">
                        <input type="number" id="inner-max" class="dimension-input" placeholder="To" step="0.001" min="0">
                    </div>
</div>

            <div class="dimension-field">
                <label>
                    @T("Outer Diameter (D)")</label>
                    <div class="dimension-range-inputs">
                        <input type="number" id="outer-min" class="dimension-input" placeholder="From" step="0.001" min="0">
                        <input type="number" id="outer-max" class="dimension-input" placeholder="To" step="0.001" min="0">
                    </div>
</div>

            <div class="dimension-field">
                <label>
                    @T("Thickness")</label>
                    <div class="dimension-range-inputs">
                        <input type="number" id="thick-min" class="dimension-input" placeholder="From" step="0.001" min="0">
                        <input type="number" id="thick-max" class="dimension-input" placeholder="To" step="0.001" min="0">
                    </div>
</div>
            <button type="submit" class="dimension-submit-button">@T("Search by Dimensions")</button>

        </div>

    </form>
</div>


<script asp-location="Footer">
    function isEmpty(v){ return v === null || v === undefined || (''+v).trim()===''; }
    function toNum(v){
        if (isEmpty(v)) return null;
        var x = parseFloat((''+v).replace(',', '.'));
        return isNaN(x) ? null : x;
    }
    function addRange(params, attr, fromVal, toVal){
        if (fromVal === null && toVal === null) return;
        params.push('attr=' + encodeURIComponent(attr));
        if (fromVal !== null) params.push('from=' + encodeURIComponent(fromVal));
        if (toVal !== null) params.push('to=' + encodeURIComponent(toVal));
    }

    $(document).ready(function () {
        $('#dimension-search-form').on('submit', function(e){
            e.preventDefault();

            var actionUrl = $(this).attr('action');
            var q = ($('#dimension-search-query').val() || '').trim();

            var params = [];
            params.push('q=' + encodeURIComponent(q));

            var errors = [];
            var hasAny = false;

            var inFrom = toNum($('#inner-min').val());
            var inTo   = toNum($('#inner-max').val());
            if (inFrom !== null || inTo !== null){
                if (inFrom !== null && inTo !== null && inFrom > inTo) errors.push('InnerDiameter: From cannot be greater than To');
                addRange(params, 'InnerDiameter', inFrom, inTo);
                hasAny = true;
            }

            var outFrom = toNum($('#outer-min').val());
            var outTo   = toNum($('#outer-max').val());
            if (outFrom !== null || outTo !== null){
                if (outFrom !== null && outTo !== null && outFrom > outTo) errors.push('OuterDiameter: From cannot be greater than To');
                addRange(params, 'OuterDiameter', outFrom, outTo);
                hasAny = true;
            }

            var thFrom = toNum($('#thick-min').val());
            var thTo   = toNum($('#thick-max').val());
            if (thFrom !== null || thTo !== null){
                if (thFrom !== null && thTo !== null && thFrom > thTo) errors.push('Thickness: From cannot be greater than To');
                addRange(params, 'Thickness', thFrom, thTo);
                hasAny = true;
            }

            if (errors.length){
                $('#dimension-messages').html(errors.map(function(x){ return '<div class="message error-message">'+x+'</div>'; }).join(''));
                return false;
            }

            if (!hasAny){
                $('#dimension-messages').html('<div class="message error-message">Please enter at least one range.</div>');
                return false;
            }

            window.location.href = actionUrl + '?' + params.join('&');
            return false;
        });

        $('.dimension-input').on('keypress', function(e){
            if (e.which === 13){
                e.preventDefault();
                $('#dimension-search-form').submit();
            }
        });
    });
</script>


<script asp-location="Footer">
    function initAlgoliaAutocomplete() {
        var $input = $('#small-searchterms');
        if (!$input.length) return;

       
        if ($input.data('ac-init')) return;
        $input.data('ac-init', true);

        function safeText(x){ return (x === null || x === undefined) ? '' : (''+x); }

        autocomplete('#small-searchterms', {
            hint: false,
            minLength: @Model.SearchTermMinimumLength,
            autoselect: true,
            appendTo: 'body'
        }, [{
            source: function (query, callback) {
                query = safeText(query).trim();
                if (!query || query.length < @Model.SearchTermMinimumLength) {
                    callback([]);
                    return;
                }

                $.ajax({
                    url: '@autoCompleteUrl',
                    method: 'GET',
                    dataType: 'json',
                    data: { term: query, size: @Model.AutoCompleteListSize }
                })
                .done(function (res) {
                    callback(res || []);
                })
                .fail(function () {
                    callback([]);
                });
            },

            templates: {
    suggestion: function (s) {

      var img = '';
      if (s.AutoCompleteImageUrl) {
        img = '<div class="item-image"><img src="' + s.AutoCompleteImageUrl + '" alt="" /></div>';
      }

      var name = safeText(s.Name);

      var manu = '';
      if (s.ManufacturerName) {
        manu = '<div class="item-manufacturer">(' + safeText(s.ManufacturerName) + ')</div>';
      }

     
      var substituteBadge = '';
      if (s.HasSubstitute === true) {
        substituteBadge =
          '<div class="item-substitute">(Substitute)</div>';
      }

      return '' +
        '<div class="autocomplete-item">' +
          img +
          '<div class="item-details">' +
            '<div class="item-name">' + name + '</div>' +
            manu +
            substituteBadge +
          '</div>' +
        '</div>';
    }
    ,
    

                empty: function (options) {
                    var q = safeText(options && options.query ? options.query : $input.val()).trim();
                    if (!q) return '<div class="no-result">No search result.</div>';

                    var searchUrl = '@Url.RouteUrl("ProductSearch")';
                    return '' +
                        '<div class="no-result">' +
                            '<div>No search result for "<strong>' + q + '</strong>".</div>' +
                            '<div style="margin-top:8px;">' +
                                '<a class="btn btn-primary" href="' + searchUrl + '?q=' + encodeURIComponent(q) + '">' +
                                    'Search for "' + q + '"' +
                                '</a>' +
                            '</div>' +
                        '</div>';
                }
                @if (!Model.HidePoweredByAlgolia)
                {
                        <text>,footer: '<div class="search-footer">Powered by Algolia</div>'</text>
                }
            }
        }]).on('autocomplete:selected', function (event, suggestion) {
            // ✅ server already gives final URL
            if (suggestion && suggestion.Url) {
                window.location.href = suggestion.Url;
                return;
            }

            // fallback
            if (suggestion && suggestion.Id) {
                window.location.href = '@webHelper.GetStoreLocation()' + 'productdetails/' + suggestion.Id;
            }
        });
    }

    $(document).ready(function () {

        // init at page load (item tab is default visible)
        initAlgoliaAutocomplete();

        const $tabs = $(".search-tab");
        const $forms = $(".search-form");

        $tabs.on("click", function (e) {
            e.preventDefault();
            e.stopPropagation();

            var target = $(this).data("tab");

            $tabs.removeClass("active");
            $forms.removeClass("active").hide();

            $(this).addClass("active");

            var $targetForm = $('.search-form[data-form="' + target + '"]')
                .addClass("active")
                .show();

            // ✅ when switching back to item tab, ensure autocomplete input is ready
            if (target === 'item') {
                initAlgoliaAutocomplete();
                $('#small-searchterms').focus();
            }
        });

        $(document).on("click", function (e) {
            if (
                !$(e.target).closest(".search-tabs-container").length &&
                !$(e.target).closest(".search-form").length
            ) {
                $tabs.removeClass("active");
                $forms.removeClass("active").hide();

                $('.search-tab[data-tab="item"]').addClass("active");
                $('#item-search-form').addClass("active").show();

                initAlgoliaAutocomplete();
            }
        });

    });
</script>

@await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.SearchBox })
<script asp-location="Footer">
    $(document).ready(function () {

        const urlParams = new URLSearchParams(window.location.search);
        const searchValue = urlParams.get("q");

        if (searchValue) {
            $("#small-searchterms").val(decodeURIComponent(searchValue));
        }

    });
</script>