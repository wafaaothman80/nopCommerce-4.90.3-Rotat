<link rel="stylesheet" type="text/css" href="/Themes/Prisma/Content/scripts/intlTelInput.css" />
<form class="otpform" asp-controller="Home" asp-action="RegisterCustomerOTP">

    <span class="titel">
        @T("من فضلك إدخل رقم الهاتف")

    </span>
    <div class="phonelockK">
        <input type="hidden" id="CodePhoneNumber" name="CodePhoneNumber" value="">


        <input type="tel" id="PhoneNumber" class="bxinputotp" name="PhoneNumber" data-intl-tel-input-id="0" title="@T("يرجى إدخال رقم الهاتف الصحيح")" oninvalid="this.setCustomValidity('@T("يرجى إدخال رقم الهاتف الصحيح")') " oninput="setCustomValidity('')" maxlength="15" placeholder="Phone Number"><br>
    </div>

    <input type="submit" value="@T("Submit")" class="butop" id="submitButton" disabled>
    <P class="field-validation-error otperroe" style="display: none;text-align: center;margin-top: 10px !important;">@T("يرجى إدخال رقم الهاتف الصحيح")</P>

</form>






<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script type="text/javascript" src="/Themes/Prisma/Content/scripts/intlTelInput.js"></script>

<script>
    $(document).ready(function () {
        var input = document.querySelector("#PhoneNumber");
        window.intlTelInput(input, {
            onlyCountries: ['AE'], // السماح فقط بالإمارات
            separateDialCode: true,
            initialCountry: "AE", // تعيين الإمارات كدولة افتراضية
            utilsScript: "/Themes/Prisma/Content/scripts/utils.js"
        });
    });
</script>

<script>
    $(document).ready(function () {
        $('#PhoneNumber').on('input', function () {
            var value = $(this).val();

            // If the number starts with '0', remove the leading zero
            if (value.startsWith('0')) {
                $(this).val(value.substring(1)); // Remove the leading zero
                this.setCustomValidity('يرجى إدخال رقم الهاتف الصحيح');
            } else {
                this.setCustomValidity('');
            }
        });
    });
    $("#otpform").on("beforeSubmit", function (event) {
        debugger;
        event.preventDefault();
        var code = $('.iti__selected-dial-code').html().replace('+', '');
        alert(code);

    });
</script>
<script>
    $(document).ready(function () {
        // إنشاء المراقب
        const observer = new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
                // عند التغيير في النص داخل الـ div
                // alert($('.iti__selected-dial-code').text());

                $('#CodePhoneNumber').val($('.iti__selected-dial-code').text().replace('+', ''));

            });
        });

        // الإعدادات لمراقبة التغييرات
        const config = { childList: true, subtree: true };

        // استهداف العنصر الذي يحتوي على القيمة
        const targetNode = document.querySelector('.iti__selected-dial-code');

        // بدء المراقبة
        observer.observe(targetNode, config);

    });

</script>
<script>
    document.getElementById('PhoneNumber').addEventListener('input', function (e) {
        // Remove any non-numeric characters
        this.value = this.value.replace(/[^0-9]/g, '');
    });
</script>
