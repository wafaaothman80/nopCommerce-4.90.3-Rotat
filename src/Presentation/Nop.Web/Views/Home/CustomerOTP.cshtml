    $("#confirmOtp").click(function () {

        var EnteredOTP = ($('input[name*="txtOTP1"]').val() + $('input[name*="txtOTP2"]').val() + $('input[name*="txtOTP3"]').val() + $('input[name*="txtOTP4"]').val());
         
           $.ajax({
