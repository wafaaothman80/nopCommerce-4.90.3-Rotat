<script>
    function startCounter(durationInSeconds) {
        let timer = durationInSeconds;
        const counterElement = document.getElementById('counter');
        const confirmOtpButton = document.getElementById('REconfirmOtp');

        // Disable the confirmOtpButton at the beginning
        confirmOtpButton.disabled = true;

        const countdown = setInterval(function () {
            const minutes = Math.floor(timer / 60);
            const seconds = timer % 60;

            counterElement.textContent = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;

            if (timer <= 0) {
                clearInterval(countdown);
                counterElement.textContent = "OTP is not valid Or Expired.";

                // Enable the confirmOtpButton after the countdown
                confirmOtpButton.disabled = false;
            } else {
                timer--; // Decrease the timer by 1 second
            }
        }, 1000);

        // Add a click event listener to the confirmOtpButton
        confirmOtpButton.addEventListener('click', function () {
            // Redirect to a new URL
            var newUrl = window.location.origin + window.location.pathname + "?key=REconfirmOtp";
            window.location.href = newUrl;
        });
    }

    // Set the duration in seconds (3 minutes = 180 seconds)
    const durationInSeconds = 180;

    // Start the counter when the page loads
    window.onload = function () {
        document.getElementById('txtOTP1').focus();
        startCounter(durationInSeconds);
    };
</script>