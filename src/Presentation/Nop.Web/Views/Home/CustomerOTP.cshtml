               type: "GET",
                url: "@(Url.Action("ConfirmCustomerOTP", "Home"))",
                data: {
                "CID": CID, "OTP": EnteredOTP, NewPhoneNumber: '@TempData["UserName"]'




               },
               success: function (data, textStatus, jqXHR) {
                  
                   if (data=='Done')
                   {
                        var protocol = location.protocol;
                        var slashes = protocol.concat("//");
                        var host = slashes.concat(window.location.host);
                        // alert(host + "//Login")

                        window.open(host + "/register", "_self")
                   }else{

                       $('#error-messageOTP').text(InvalidOTP);
                       $('#txtOTP1, #txtOTP2, #txtOTP3, #txtOTP4').val('');
                       document.getElementById('txtOTP1').focus();

                   }

               }
           });

      
    });











</script>
<script>
    function focusNextInput(currentInput, nextInputId) {
        const maxLength = parseInt(currentInput.getAttribute('maxlength'), 10);
        const currentLength = currentInput.value.length;

        if (currentLength >= maxLength) {
            const nextInput = document.getElementById(nextInputId);

            if (nextInput) {
                nextInput.focus();
            }
        }
    }
</script>









