<script>
    $(document).ready(function () {
        // استهداف حقول الإدخال وزر التأكيد باستخدام jQuery
        var otpInputs = $('.input');
        var confirmButton = $('#confirmOtp');

        // إضافة استماع للتحقق من النقر على زر التأكيد
        confirmButton.on('click', function () {
            // التحقق من أن جميع حقول الإدخال مملوءة
            var isFilled = true;
            otpInputs.each(function () {
                if ($(this).val().trim() === '') {
                    isFilled = false;
                    return false; // توقف الفحص عند العثور على حقل فارغ
                }
            });

            // عرض تنبيه إذا لم تكن جميع حقول الإدخال مملوءة
            if (!isFilled) {
                $("#error-messageOTPs").css("display", "block");

            }
        });
    });
</script>
<script>
    // Function to focus on the next input field
    function focusNextInput(currentInput, nextInputId) {
        // Ensure the current input has a valid number
        if (currentInput.value.length === 1) {
            document.getElementById(nextInputId).focus();
        }
        // Check if all inputs are filled
        checkOtpFilled();
    }

    // Function to check if all OTP inputs are filled
    function checkOtpFilled() {
        // Get the values of all OTP inputs
        const otp1 = document.getElementById('txtOTP1').value;
        const otp2 = document.getElementById('txtOTP2').value;
        const otp3 = document.getElementById('txtOTP3').value;
        const otp4 = document.getElementById('txtOTP4').value;

        // Check if all fields have values (i.e., OTP is complete)
        if (otp1 && otp2 && otp3 && otp4) {
            // If complete, automatically trigger the click event for the confirm button
            document.getElementById('confirmOtp').click();
        }
    }

    // Adding event listeners to inputs to allow only one digit
    document.querySelectorAll('.input').forEach(input => {
        input.addEventListener('input', function () {
            if (this.value.length > 1) {
                this.value = this.value.slice(0, 1); // Keep only one digit
            }
        });
    });

    

    // Simulate OTP confirmation when the confirm button is clicked
    document.getElementById('confirmOtp').addEventListener('click', function () {
        // Simulate confirmation action (e.g., form submission or alert)

    });

    // Focus on the first input when the page is loaded
    window.onload = function () {
        document.getElementById('txtOTP1').focus();
    };
</script>





<script>
    $(document).ready(function () {
        $('.input').on('keypress', function (e) {
            // السماح فقط بالأرقام (0-9)
            if (e.which < 48 || e.which > 57) {
                e.preventDefault(); // منع الإدخال
            }
        });

        // التحقق أيضًا أثناء إدخال النصوص (للصق مثلاً)
        $('.input').on('input', function () {
            const value = $(this).val();
            if (/[^0-9]/.test(value)) {
                $(this).val(value.replace(/[^0-9]/g, '')); // إزالة أي حروف غير رقمية
            }
        });
    });
</script>

<script>
    // Focus next input when typing in current input
    function focusNextInput(currentInput, nextInputId) {
        if (currentInput.value.length === currentInput.maxLength) {
            document.getElementById(nextInputId).focus();
        }
    }

    // Add event listener to each OTP field to check if all inputs are filled
    const otpInputs = document.querySelectorAll('.input');
    otpInputs.forEach(function (input, index) {
        input.addEventListener('input', function () {
            // Check if all inputs have values
            const allFilled = Array.from(otpInputs).every(input => input.value.length === 1);

            // If all inputs are filled, trigger the confirm button click
            if (allFilled) {
                document.getElementById('confirmOtp').click(); // Trigger confirm button click
            }
        });
    });
</script>
