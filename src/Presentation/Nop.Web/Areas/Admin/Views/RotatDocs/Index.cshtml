@{
    //page title
    ViewBag.PageTitle = "Rotat Admin Guide";
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Rotat customizations");

    var files = (List<string>)ViewBag.Files;
    var selectedFile = (string)ViewBag.SelectedFile;

    //turn "UG-04-Quotes.md" into "Quotes"
    static string PrettyName(string fileName)
    {
        var name = System.IO.Path.GetFileNameWithoutExtension(fileName);
        name = System.Text.RegularExpressions.Regex.Replace(name, @"^UG-\d+-", "");
        return name.Replace("-", " ");
    }
}

<div class="content-header clearfix">
    <h1 class="float-left">
        Rotat Admin Guide
    </h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2">
                <div class="card card-default">
                    <div class="card-header"><strong>Sections</strong></div>
                    <div class="list-group list-group-flush">
                        @foreach (var f in files)
                        {
                            <a class="list-group-item list-group-item-action @(f == selectedFile ? "active" : "")"
                               href="@Url.Action("Index", "RotatDocs", new { file = f })">@PrettyName(f)</a>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-9 col-lg-10">
                <div class="card card-default">
                    <div class="card-body">
                        <textarea id="mdSource" style="display:none;">@ViewBag.Content</textarea>
                        <div id="doc-toc" class="rotat-doc-toc" style="display:none;">
                            <strong>On this page:</strong> <span id="doc-toc-links"></span>
                        </div>
                        <div id="doc-content" class="rotat-doc-content">
                            Loading...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .rotat-doc-toc {
        background: #f4f6f9;
        border: 1px solid #e3e6ea;
        border-radius: 6px;
        padding: 10px 15px;
        margin-bottom: 20px;
        font-size: 13px;
    }

        .rotat-doc-toc a {
            margin-right: 4px;
        }

        .rotat-doc-toc .toc-sep {
            color: #b5bcc4;
            margin-right: 8px;
        }

    .rotat-doc-content {
        max-width: 950px;
        line-height: 1.7;
        font-size: 14.5px;
    }

        .rotat-doc-content h1 {
            font-size: 27px;
            border-bottom: 2px solid #e3e6ea;
            padding-bottom: 10px;
            margin: 5px 0 20px;
        }

        .rotat-doc-content h2 {
            font-size: 20px;
            background: #f4f6f9;
            border-left: 4px solid #3c8dbc;
            border-radius: 3px;
            padding: 8px 12px;
            margin: 30px 0 14px;
        }

        .rotat-doc-content h3 {
            font-size: 16px;
            margin: 22px 0 10px;
            color: #2c3b41;
        }

        .rotat-doc-content table {
            border-collapse: collapse;
            margin: 12px 0;
            display: block;
            overflow-x: auto;
            max-width: 100%;
        }

        .rotat-doc-content th,
        .rotat-doc-content td {
            border: 1px solid #d2d6de;
            padding: 7px 14px;
            text-align: left;
            vertical-align: top;
        }

        .rotat-doc-content th {
            background: #f4f6f9;
        }

        .rotat-doc-content figure {
            margin: 18px 0;
        }

        .rotat-doc-content figcaption {
            font-size: 12.5px;
            color: #6c757d;
            padding-top: 6px;
        }

        .rotat-doc-content blockquote {
            border-left: 4px solid #f39c12;
            background: #fff8ec;
            border-radius: 3px;
            margin: 14px 0;
            padding: 10px 15px;
        }

            .rotat-doc-content blockquote p {
                margin: 0;
            }

        .rotat-doc-content ol li,
        .rotat-doc-content ul li {
            margin-bottom: 5px;
        }
</style>

<script src="~/js/marked.min.js"></script>
<script>
    (function () {
        var source = document.getElementById('mdSource').value;
        var target = document.getElementById('doc-content');
        target.innerHTML = marked.parse(source);

        //links between guide files open within this page
        target.querySelectorAll('a[href$=".md"]').forEach(function (a) {
            var name = a.getAttribute('href').split('/').pop();
            a.setAttribute('href', '@Url.Action("Index", "RotatDocs")?file=' + encodeURIComponent(name));
        });

        //build the "On this page" outline from the section headings
        var headings = target.querySelectorAll('h2');
        if (headings.length > 1) {
            var linksHolder = document.getElementById('doc-toc-links');
            headings.forEach(function (h, i) {
                var id = 'sec-' + i;
                h.id = id;
                var a = document.createElement('a');
                a.href = '#' + id;
                a.textContent = h.textContent;
                linksHolder.appendChild(a);
                if (i < headings.length - 1) {
                    var sep = document.createElement('span');
                    sep.className = 'toc-sep';
                    sep.textContent = ' · ';
                    linksHolder.appendChild(sep);
                }
            });
            document.getElementById('doc-toc').style.display = 'block';
        }
    })();
</script>
