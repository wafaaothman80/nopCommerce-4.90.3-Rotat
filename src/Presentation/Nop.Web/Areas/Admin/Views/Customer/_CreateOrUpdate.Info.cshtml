    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="SelectedAccountManagerIds" />
           
        </div>
        <div class="col-md-9">
            <nop-select asp-for="SelectedAccountManagerIds"
                        asp-items="Model.AvailableAccountManagers"
                        asp-multiple="true" />
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-3">
            <label><strong>Primary Account Manager</strong></label>
            <small class="text-muted d-block">Changing this updates ★ in the list above</small>
        </div>
        <div class="col-md-9">
            <select id="PrimaryAccountManagerId" name="PrimaryAccountManagerId" class="form-control"></select>
            <script>
                $(function () {
                    var selectedIds   = [@Html.Raw(string.Join(",", Model.SelectedAccountManagerIds))];
                    var allOptions    = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                                           Model.AvailableAccountManagers.ToDictionary(x => x.Value, x => x.Text)));

                    var $multi        = $('#@Html.IdFor(m => m.SelectedAccountManagerIds)');
                    var $primary      = $('#PrimaryAccountManagerId');
                    var isReinit      = false;
                    // Use a JS variable so templateSelection can read it before the DOM is ready
                    var currentPrimaryId = @Model.PrimaryAccountManagerId;

                    /* Format item — ★ when item.id === currentPrimaryId */
                    function formatAM(item, isResult) {
                        if (!item.id) return item.text;
                        if (parseInt(item.id) === currentPrimaryId) {
                            var extra = isResult
                                ? ' <span class="badge badge-warning ml-1">Primary</span>'
                                : '';
                            return $('<span style="color:#e6a817;font-weight:bold;">★ ' + item.text + extra + '</span>');
                        }
                        return item.text;
                    }

                    /* Init / re-init Select2 */
                    function initMultiSelect() {
                        $multi.select2({
                            placeholder       : 'Select account manager(s)',
                            allowClear        : true,
                            templateResult    : function(i) { return formatAM(i, true);  },
                            templateSelection : function(i) { return formatAM(i, false); }
                        });
                    }

                    /* Rebuild Primary dropdown from current multi-select values */
                    function rebuildPrimaryDropdown(keepVal) {
                        var chosen = $multi.val() || [];
                        var prev   = keepVal !== undefined ? String(keepVal) : ($primary.val() || '0');
                        $primary.empty().append('<option value="0">— Select primary —</option>');
                        chosen.forEach(function(id) {
                            $primary.append($('<option>').val(id).text(allOptions[id] || id));
                        });
                        var newVal = chosen.indexOf(prev) >= 0 ? prev : (chosen[0] || '0');
                        $primary.val(newVal);
                        currentPrimaryId = parseInt(newVal) || 0;
                    }

                    /* Re-render Select2 chips with updated ★ */
                    function refreshStars() {
                        isReinit = true;
                        var vals = $multi.val();
                        $multi.select2('destroy');
                        initMultiSelect();
                        $multi.val(vals).trigger('change'); // isReinit=true → change handler returns early
                        isReinit = false;
                    }

                    /* ── Boot sequence ── */
                    // 1. Build primary dropdown first so currentPrimaryId is set
                    // Temporarily populate options from selectedIds
                    selectedIds.forEach(function(id) {
                        $primary.append($('<option>').val(id).text(allOptions[id] || id));
                    });
                    $primary.val(String(currentPrimaryId));

                    // 2. Init Select2 — templateSelection now reads correct currentPrimaryId
                    initMultiSelect();
                    $multi.val(selectedIds).trigger('change');

                    // 3. Rebuild primary dropdown properly (keeps currentPrimaryId)
                    rebuildPrimaryDropdown(currentPrimaryId);

                    /* When multi-select changes → sync primary dropdown + re-render stars */
                    $multi.on('change', function () {
                        if (isReinit) return;
                        rebuildPrimaryDropdown();
                        refreshStars();
                    });

                    /* When admin picks a different primary → update variable + re-render ★ */
                    $primary.on('change', function () {
                        if (isReinit) return;
                        currentPrimaryId = parseInt($primary.val()) || 0;
                        refreshStars();
                    });
                });
            </script>
        </div>
    </div>

