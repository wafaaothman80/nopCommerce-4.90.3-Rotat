    <script>
        $(function () {
            var activeCheckbox = $('input[name="Active"]');
            var erpActionSelect = $('#ERPActionDropdown');
            var erpActionRow = $("#erp-action-row");
            var erpUpdateBox = $("#erp-update-box");
            var erpCustomerIdToUpdate = $('#ERPCustomerIdToUpdate');


            @if (Model.ERPCustomerId > 0)
            {
                        <text>
                            erpActionSelect.find("option[value='1']").remove();
                            erpActionSelect.val("2");
                            erpUpdateBox.show();
                        </text>
            }
            else
            {
                        <text>

                            erpActionSelect.val("1");
                        </text>
            }

            function toggleErpAction() {
                if (activeCheckbox.is(":checked")) {
                    erpActionRow.show();
                    toggleErpUpdateBox();
                } else {
                    erpActionRow.hide();
                    erpUpdateBox.hide();
                    erpActionSelect.val("");

                }
            }

            function toggleErpUpdateBox() {
                if (erpActionSelect.val() === "2") {
                    erpUpdateBox.show();
                } else {
                    erpUpdateBox.hide();

                }
            }


            activeCheckbox.on("change", toggleErpAction);
            erpActionSelect.on("change", toggleErpUpdateBox);


            toggleErpAction();
        });
    </script>







