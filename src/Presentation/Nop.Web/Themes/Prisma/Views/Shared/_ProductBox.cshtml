@model ProductOverviewModel

@using Nop.Core
@using Nop.Core.Domain.Catalog
@using Nop.Core.Domain.Orders
@using Nop.Core.Domain.Tax
@using Nop.Services.Configuration
@using System;
@using System.Globalization;
@using System.Text.RegularExpressions;
@inject Nop.Services.Catalog.IProductService ProductService
@inject CatalogSettings catalogSettings
@inject IStoreContext storeContext
@inject IWorkContext workContext
@inject ISettingService settingService
@inject IViewComponentSelector viewComponentSelector
@using Nop.Core.Domain.Catalog
@inject Nop.Services.Catalog.ICategoryService CategoryService
@inject Nop.Services.Seo.IUrlRecordService UrlRecordService
@inject Nop.Services.Catalog.IManufacturerService ManufacturerService
@inject Nop.Services.Localization.ILocalizationService LocalizationService


@{
    //prepare "Add to cart" AJAX link
    var addtocartlink = "";
    var shoppingCartTypeId = (int)ShoppingCartType.ShoppingCart;
    var quantity = 1;
    if (Model.ProductPrice.ForceRedirectionAfterAddingToCart)
    {
        addtocartlink = Url.RouteUrl("AddProductToCart-Catalog", new { productId = Model.Id, shoppingCartTypeId = shoppingCartTypeId, quantity = quantity, forceredirection = Model.ProductPrice.ForceRedirectionAfterAddingToCart });
    }
    else
    {
        addtocartlink = Url.RouteUrl("AddProductToCart-Catalog", new { productId = Model.Id, shoppingCartTypeId = shoppingCartTypeId, quantity = quantity });
    }

    var addtowishlistlink = Url.RouteUrl("AddProductToCart-Catalog", new { productId = Model.Id, shoppingCartTypeId = (int)ShoppingCartType.Wishlist, quantity = quantity });
    var addtocomparelink = Url.RouteUrl("AddProductToCompare", new { productId = Model.Id });

    var storeId = (await storeContext.GetCurrentStoreAsync()).Id;
    var lazyLoadImages = await settingService.GetSettingByKeyAsync("PrismaThemeSettings.LazyLoadImages", false, storeId, true);

    var product = await ProductService.GetProductByIdAsync(Model.Id);

    var StockQuantity = await ProductService.GetTotalStockQuantityAsync(product);
    var CurrentCustomer = await workContext.GetCurrentCustomerAsync();
    var mappings = await CategoryService.GetProductCategoriesByProductIdAsync(product.Id, true);
    var firstMapping = mappings?.OrderBy(pc => pc.DisplayOrder).FirstOrDefault();

    Nop.Core.Domain.Catalog.Category category = null;
    string categoryName = "";
    string categorySeName = "";

    if (firstMapping != null)
    {
        category = await CategoryService.GetCategoryByIdAsync(firstMapping.CategoryId);

        if (category != null)
        {
            var workingLanguage = await workContext.GetWorkingLanguageAsync();

            categoryName = await LocalizationService.GetLocalizedAsync(category, x => x.Name, workingLanguage.Id);
            categorySeName = await UrlRecordService.GetSeNameAsync(category, workingLanguage.Id);

            if (string.IsNullOrWhiteSpace(categoryName))
                categoryName = category.Name;
        }
    }

    var brandMappings = await ManufacturerService.GetProductManufacturersByProductIdAsync(product.Id, true);
    var firstBrandMapping = brandMappings?.OrderBy(pm => pm.DisplayOrder).FirstOrDefault();

    string brandName = ""; // Default fallback

    if (firstBrandMapping != null)
    {
        var brand = await ManufacturerService.GetManufacturerByIdAsync(firstBrandMapping.ManufacturerId);
        if (!string.IsNullOrEmpty(brand?.Name))
        {
            brandName = brand.Name;
        }
    }

   
    var isSubstituteResult =
        Model.CustomProperties != null
        && Model.CustomProperties.TryGetValue("IsSubstituteResult", out var subFlag)
        && string.Equals(subFlag, "true", StringComparison.OrdinalIgnoreCase);

    var substituteText = T("Substitute").Text;



    var priceText = Model.ProductPrice.Price ?? "";
    decimal parsedPrice = 0;

    if (!string.IsNullOrWhiteSpace(priceText))
    {
        if (!decimal.TryParse(priceText, NumberStyles.Currency, CultureInfo.GetCultureInfo("en-US"), out parsedPrice))
        {
            var cleaned = Regex.Replace(priceText, @"[^\d.-]", "");
            if (!decimal.TryParse(cleaned, NumberStyles.Any, CultureInfo.InvariantCulture, out parsedPrice))
            {
                parsedPrice = 0; 
            }
        }
    }

    var isZeroPrice = parsedPrice == 0;


}
