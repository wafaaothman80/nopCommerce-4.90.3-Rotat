<script>
    $('.item-box').each(function () {
        var $box = $(this);

        // نجيب الـ add-Logined اللي جوه البلوك الحالي
        var $priceBlock = $box.find('.home-page-body .add-Logined');

        // نحطه جوه الـ logpric في نفس البلوك
        $box.find('.home-page-body .logpric').append($priceBlock);
    });
</script>
<script asp-location="Footer">
    $(document).ready(function () {
        setInterval(function () {
            $('.item-box').each(function () {
                var $itemBox = $(this);
                var $outOfStock = $itemBox.find('.outofstok');

                if ($outOfStock.length > 0 && $outOfStock.is(':visible')) {

                    if (!$itemBox.hasClass('disaplebut')) {

                        $itemBox.addClass('disaplebut');

                        // تعطيل أزرار الكارت والكمية
                        var $ajaxCartButtonWrapper = $itemBox.find('.ajax-cart-button-wrapper');
                        $ajaxCartButtonWrapper.addClass('disabled-wrapper');
                        $ajaxCartButtonWrapper.find('.productQuantityTextBox').prop('disabled', true);
                        $ajaxCartButtonWrapper.find('.product-box-add-to-cart-button').prop('disabled', true).addClass('disabled');
                        $ajaxCartButtonWrapper.css('opacity', '0.3');

                        // 🔥 إزالة السعر نفسه فقط
                        $itemBox.find('.price.actual-price').text('');
                    }
                }
            });
        }, 0);
    });
</script>

<script asp-location="Footer">
    document.querySelectorAll('.product-item').forEach(function (product) {

        var price = product.querySelector('.actual-price');
        var buttonWrap = product.querySelector('.buttons.but1');

        if (price) {
            var priceText = price.textContent.replace(/[^0-9.]/g, '');

            if (parseFloat(priceText) === 0) {
                buttonWrap.classList.add('price-zero');
            }
        }

    });
</script>

<script asp-location="Footer">
    function checkOnRequest() {
        document.querySelectorAll('.details').forEach(function (el) {
            var price = el.querySelector('.price.actual-price');

            if (price && price.textContent.trim() === 'On Request') {
                el.classList.add('OnRequest');
            }
        });
    }

    // أول تحميل
    document.addEventListener("DOMContentLoaded", checkOnRequest);

    // متابعة أي تغيير (Ajax)
    const observer = new MutationObserver(checkOnRequest);
    observer.observe(document.body, { childList: true, subtree: true });
</script>

<script asp-location="Footer">
(function () {
    // كل product box بيسجّل الـ ID بتاعه
    window._wishlistBoxIds = window._wishlistBoxIds || [];
    window._wishlistBoxIds.push('@Model.Id');

    // debounce: بنستنى لغاية ما كل الـ boxes تتسجّل، بعدين نعمل request واحدة
    if (window._wishlistBoxTimer) clearTimeout(window._wishlistBoxTimer);
    window._wishlistBoxTimer = setTimeout(function () {
        var ids = window._wishlistBoxIds || [];
        if (!ids.length) return;

        var wishlistUrl = ($('.wishlist-button a.ico-wishlist').attr('href')
            || $('a.ico-wishlist').attr('href')
            || $('a[href*="wishlist"]').first().attr('href')
            || '/wishlist'
        ).trim();

        console.log('[WishlistBox] url=' + wishlistUrl + ' ids=' + JSON.stringify(ids));

        $.ajax({
            url: wishlistUrl,
            type: 'GET',
            cache: false,
            success: function (html) {
                var $html = $('<div>').html(html);

                ids.forEach(function (pid) {
                    pid = String(pid);
                    var found = false;

                    $html.find('a[href]').each(function () {
                        if (($(this).attr('href') || '').indexOf(pid) !== -1) {
                            found = true;
                            return false;
                        }
                    });

                    if (!found) {
                        $html.find('button, input').each(function () {
                            if (($(this).attr('onclick') || '').indexOf(pid) !== -1) {
                                found = true;
                                return false;
                            }
                        });
                    }

                    console.log('[WishlistBox] pid=' + pid + ' found=' + found + ' btn=' + $('#add-wishlist-modal-btn-' + pid).length);
                    if (found) {
                        $('#add-wishlist-modal-btn-' + pid).addClass('Active');
                    }
                });
            },
            error: function (xhr) {
                console.log('[WishlistBox] AJAX error', xhr.status);
            }
        });
    }, 300);

    // capture-phase listener — يشتغل قبل inline onclick وقبل أي jQuery handler
    if (!window._wishlistCaptureOverrideDone) {
        window._wishlistCaptureOverrideDone = true;

        document.addEventListener('click', function (e) {
            // ابحث عن الزرار في مسار الحدث
            var btn = e.target;
            while (btn && btn !== document) {
                if (btn.classList && btn.classList.contains('add-to-wishlist-button')) break;
                btn = btn.parentElement;
            }
            if (!btn || btn === document || !btn.classList.contains('add-to-wishlist-button')) return;

            // فقط أزرار الـ catalog (add-wishlist-modal-btn-*) وليس زر المنتج الأساسي (add-to-wishlist-button-*)
            if (!btn.id || !btn.id.startsWith('add-wishlist-modal-btn-')) return;

            // وقف الحدث — inline onclick مش هيشتغل، jQuery handlers مش هتشتغل
            e.stopPropagation();
            e.preventDefault();

            // جيب الـ product ID
            var pid = btn.id.replace('add-wishlist-modal-btn-', '');
            if (!pid) {
                var m = (btn.getAttribute('onclick') || '').match(/['"](\d+)['"]/);
                if (m) pid = m[1];
            }
            if (!pid) return;

            var $btn = $(btn);

            if ($btn.hasClass('Active')) {
                // إزالة من الويشليست
                $btn.removeClass('Active');
                wishlistRemove(pid, $btn);
            } else {
                // إضافة للويشليست
                $btn.addClass('Active');
                wishlistAdd(pid, $btn);
            }
        }, true); // true = capture phase

        function updateWishlistCounter(delta) {
            $('.wishlist-qty').each(function () {
                var n = parseInt($(this).text(), 10) || 0;
                $(this).text(Math.max(0, n + delta));
            });
        }

        function wishlistAdd(pid, $btn) {
            var url = '/addproducttocart/catalog/' + pid + '/2/1';

            var _origNotify = window.displayBarNotification;
            window.displayBarNotification = function () {};
            if (window.AjaxCart && typeof AjaxCart.addproducttocart_catalog === 'function') {
                AjaxCart.addproducttocart_catalog(url);
            } else {
                $.ajax({ url: url, type: 'POST', cache: false,
                    data: window.addAntiForgeryToken ? addAntiForgeryToken({}) : {} });
            }
            setTimeout(function () { window.displayBarNotification = _origNotify; }, 1000);
            updateWishlistCounter(1);
        }

        function wishlistRemove(pid, $btn) {
            var wishlistUrl = ($('.wishlist-button a.ico-wishlist, a.ico-wishlist').first().attr('href') || '/wishlist').trim();
            $.ajax({
                url: wishlistUrl, type: 'GET', cache: false,
                success: function (html) {
                    var $html = $('<div>').html(html);
                    var $removeInput = null;
                    $html.find('tr').each(function () {
                        if (($(this).html() || '').indexOf(pid) !== -1) {
                            $removeInput = $(this).find('input[name="removefromcart"]');
                            return false;
                        }
                    });
                    var $form = $html.find('form').first();
                    if (!$removeInput || !$removeInput.length || !$form.length) {
                        verifyBtn(pid, $btn);
                        return;
                    }
                    var data = {};
                    $form.find('input, select, textarea').each(function () {
                        var $el = $(this), name = $el.attr('name'), type = ($el.attr('type') || '').toLowerCase();
                        if (!name) return;
                        if (type === 'checkbox' || type === 'radio') { if ($el.prop('checked')) data[name] = $el.val() || 'on'; }
                        else data[name] = $el.val();
                    });
                    data[$removeInput.attr('name')] = $removeInput.val() || 'true';
                    data['updatecart'] = 'Update wishlist';
                    $.ajax({
                        url: $form.attr('action') || wishlistUrl,
                        type: ($form.attr('method') || 'post').toUpperCase(),
                        data: data,
                        success: function () { updateWishlistCounter(-1); },
                        complete: function () { verifyBtn(pid, $btn); }
                    });
                },
                error: function () { verifyBtn(pid, $btn); }
            });
        }

        function verifyBtn(pid, $btn) {
            var wishlistUrl = ($('.wishlist-button a.ico-wishlist, a.ico-wishlist').first().attr('href') || '/wishlist').trim();
            $.ajax({
                url: wishlistUrl, type: 'GET', cache: false,
                success: function (html) {
                    var $html = $('<div>').html(html), found = false;
                    $html.find('a[href]').each(function () {
                        if (($(this).attr('href') || '').indexOf(pid) !== -1) { found = true; return false; }
                    });
                    if (!found) {
                        $html.find('button,input').each(function () {
                            if (($(this).attr('onclick') || '').indexOf(pid) !== -1) { found = true; return false; }
                        });
                    }
                    $btn.toggleClass('Active', found);
                }
            });
        }
    }
})();
</script>


