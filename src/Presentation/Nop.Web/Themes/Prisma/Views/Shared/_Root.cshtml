<script>
    $(document).ready(function () {
        // دالة لتحديث ارتفاع السلايدر
        function updateSliderHeight() {
            if (window.innerWidth > 1200) {
                var sliderHeight = $('.catmenu').outerHeight();
                $('.slidehome .slider-wrapper img').css('height', sliderHeight + 'px');
            } else {
                // إعادة تعيين الارتفاع إذا كانت الشاشة أصغر من 1200
                $('.slidehome .slider-wrapper img').css('height', 'auto');
            }
        }

        // استدعاء الدالة عند تحميل الصفحة
        updateSliderHeight();

        // استدعاء الدالة عند تغيير أبعاد الصفحة
        $(window).resize(function () {
            updateSliderHeight();
        });
    });
</script>
<script>
    $(document).ready(function () {
        var wishlistIdsCache = {};
        var wishlistMetaCache = {};
        var refreshTimer = null;
        var isRefreshing = false;

        function getWishlistUrl() {
            var $link = $('.wishlist-button a.ico-wishlist, .header-links a.ico-wishlist').first();
            return $link.attr('href') || '/wishlist';
        }

        function extractProductIdFromButton($btn) {
            var id = 0;

            id = parseInt($btn.data('productid'), 10) || 0;
            if (id) return id;

            var btnId = $btn.attr('id') || '';
            var match = btnId.match(/(\d+)/);
            if (match) return parseInt(match[1], 10) || 0;

            var onclick = $btn.attr('onclick') || '';
            match = onclick.match(/['"](\d+)['"]/);
            if (match) return parseInt(match[1], 10) || 0;

            match = onclick.match(/\/details\/(\d+)\//i);
            if (match) return parseInt(match[1], 10) || 0;

            match = onclick.match(/\/(\d+)\/2/i);
            if (match) return parseInt(match[1], 10) || 0;

            return 0;
        }

        function normalizeUrl(url) {
            if (!url) return '';
            var a = document.createElement('a');
            a.href = url;
            return (a.pathname || '').toLowerCase().replace(/\/+$/, '');
        }

        function extractWishlistState(html) {
            var ids = {};
            var meta = {};
            var $html = $('<div>').html(html);

            $html.find('tr, .item, .wishlist-item, .product').each(function () {
                var $row = $(this);
                var productId = 0;

                $row.find('a[href]').each(function () {
                    var href = $(this).attr('href') || '';
                    var path = normalizeUrl(href);
                    var match = path.match(/-(\d+)$/);
                    if (match) {
                        productId = parseInt(match[1], 10) || 0;
                        return false;
                    }
                });

                if (!productId) {
                    $row.find('.add-to-wishlist-button, button[id*="add-to-wishlist"], button[id*="add-wishlist"]').each(function () {
                        productId = extractProductIdFromButton($(this));
                        if (productId) return false;
                    });
                }

                if (!productId) return;

                ids[productId] = true;

                var $remove = $row.find('input[type="checkbox"][name*="removefromcart"]').first();
                if (!$remove.length) {
                    $remove = $row.find('input[type="checkbox"][name*="remove"]').first();
                }

                meta[productId] = {
                    removeName: $remove.attr('name') || '',
                    removeValue: $remove.val() || 'true'
                };
            });

            return {
                ids: ids,
                meta: meta
            };
        }

        function markButtons() {
            $('.add-to-wishlist-button').each(function () {
                var $btn = $(this);
                var productId = extractProductIdFromButton($btn);
                $btn.toggleClass('Active', !!wishlistIdsCache[productId]);
            });
        }

        function refreshWishlistButtons(delay) {
            clearTimeout(refreshTimer);

            refreshTimer = setTimeout(function () {
                if (isRefreshing) return;
                isRefreshing = true;

                $.ajax({
                    url: getWishlistUrl(),
                    type: 'GET',
                    cache: false,
                    success: function (html) {
                        var state = extractWishlistState(html);
                        wishlistIdsCache = state.ids || {};
                        wishlistMetaCache = state.meta || {};
                        markButtons();
                    },
                    complete: function () {
                        isRefreshing = false;
                    }
                });
            }, delay || 0);
        }

        function addProductToWishlist($btn) {
            var onclick = $btn.attr('onclick') || '';

            if (onclick) {
                try {
                    new Function(onclick.replace(/^return\s+/i, ''))();
                } catch (e) {
                    $btn[0].click();
                }
            } else {
                $btn.trigger('click');
            }

            var productId = extractProductIdFromButton($btn);
            if (productId) {
                wishlistIdsCache[productId] = true;
                $btn.addClass('Active');
            }

            refreshWishlistButtons(800);
        }

        function removeProductFromWishlist($btn, productId) {
            $.ajax({
                url: getWishlistUrl(),
                type: 'GET',
                cache: false,
                success: function (html) {
                    var $page = $('<div>').html(html);
                    var state = extractWishlistState(html);

                    wishlistIdsCache = state.ids || {};
                    wishlistMetaCache = state.meta || {};

                    var meta = wishlistMetaCache[productId];
                    var $form = $page.find('form').first();

                    if (!$form.length || !meta || !meta.removeName) {
                        delete wishlistIdsCache[productId];
                        $btn.removeClass('Active');
                        markButtons();
                        refreshWishlistButtons(300);
                        return;
                    }

                    var formAction = $form.attr('action') || getWishlistUrl();
                    var formMethod = ($form.attr('method') || 'post').toUpperCase();
                    var data = {};

                    $form.find('input, select, textarea').each(function () {
                        var $field = $(this);
                        var name = $field.attr('name');
                        if (!name) return;

                        var type = ($field.attr('type') || '').toLowerCase();

                        if (type === 'checkbox' || type === 'radio') {
                            if ($field.prop('checked')) {
                                data[name] = $field.val() || 'on';
                            }
                        } else {
                            data[name] = $field.val();
                        }
                    });

                    data[meta.removeName] = meta.removeValue || 'true';

                    if (!data.updatecart) data.updatecart = 'Update wishlist';

                    $.ajax({
                        url: formAction,
                        type: formMethod,
                        data: data,
                        success: function () {
                            delete wishlistIdsCache[productId];
                            $btn.removeClass('Active');
                            markButtons();
                            refreshWishlistButtons(400);
                        },
                        error: function () {
                            refreshWishlistButtons(400);
                        }
                    });
                },
                error: function () {
                    refreshWishlistButtons(400);
                }
            });
        }

        refreshWishlistButtons(0);

        $(document).on('click.wishlistToggle', '.add-to-wishlist-button', function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();

            var $btn = $(this);
            var productId = extractProductIdFromButton($btn);

            if (!productId) return false;

            if ($btn.hasClass('Active') || wishlistIdsCache[productId]) {
                removeProductFromWishlist($btn, productId);
            } else {
                addProductToWishlist($btn);
            }

            return false;
        });

        $(document).ajaxComplete(function (event, xhr, settings) {
            var url = (settings && settings.url) ? settings.url.toLowerCase() : '';

            if (url.indexOf('wishlist') !== -1 ||
                url.indexOf('addproducttocart') !== -1 ||
                url.indexOf('removefromcart') !== -1) {
                refreshWishlistButtons(250);
            }
        });
    });
</script>


