@*للسرش*@ 
<script>
$(document).ready(function () {

    var $searchBox = $('.store-search-box.newheader');
    var $originalParent = $searchBox.parent(); // المكان الأصلي
    var $originalNext = $searchBox.next();     // العنصر اللي بعده

    function moveSearchBox() {
        var $headerWrapper = $('.header-wrapper');

        if ($(window).width() <= 1200) {
            // للموبايل
            if ($searchBox.length && $headerWrapper.length) {
                if (!$searchBox.prev().is($headerWrapper)) {
                    $searchBox.insertAfter($headerWrapper);
                }
            }
        } else {
            // للديسكتوب (رجّعيه مكانه)
            if ($originalNext.length) {
                $searchBox.insertBefore($originalNext);
            } else {
                $searchBox.appendTo($originalParent);
            }
        }
    }

    // أول تحميل
    moveSearchBox();

    // عند تغيير الحجم
    $(window).on('resize', function () {
        moveSearchBox();
    });

});
</script>

<script>
$(document).ready(function () {
    $('table.data-table td.spec-value').each(function () {
        var value = $(this).text().trim();

        // أي قيمة = صفر (0 / 00 / 0.0 / 0.00)
        if (/^0+(\.0+)?$/.test(value)) {
            $(this).closest('tr').css({
                'display': 'none'
            });
        }
    });
});
</script>

<script>
    document.querySelectorAll('table.data-table .spec-value').forEach(function (el) {
    el.innerHTML = el.innerHTML.replace(/\d+\.\d+/g, function (num) {
        return num.replace(/(\.\d*?)0+$/, '$1').replace(/\.$/, '');
    });
});
</script>



