<script>
$(document).ready(function () {

    function hideZeroPrices() {
        $(".product-unit-price, .product-subtotal, .value-summary, .price span, .totals strong, .price, .product-subtotal, .product-price span")
            .each(function () {

                var text = $(this).text().trim();

                // نشيل أي رموز عملة ومسافات
                var cleanText = text.replace(/[^\d\.٫]/g, '');

                // نخفي فقط لو القيمة صفر فعلاً
                if (
                    cleanText === "0" ||
                    cleanText === "00" ||
                    cleanText === "0.00" ||
                    cleanText === "0٫00"
                ) {
                    $(this).hide();
                } else {
                    $(this).show();
                }
            });
    }

    // أول تحميل
    hideZeroPrices();

    // إعادة الفحص كل 50 ثانية
    setInterval(hideZeroPrices, 50000);
});
</script>
