@model CategoryModel

@using Nop.Core.Domain.Catalog
@using Nop.Core.Domain.Common
@using Nop.Core.Domain.Seo

@inject Nop.Core.IWebHelper webHelper
@inject SeoSettings seoSettings
@inject CommonSettings commonSettings
@inject IViewComponentSelector viewComponentSelector

@{
    Layout = "_ColumnsTwo";

    //title
    NopHtml.AddTitleParts(!string.IsNullOrEmpty(Model.MetaTitle) ? Model.MetaTitle : Model.Name);
    //meta
    NopHtml.AddMetaDescriptionParts(Model.MetaDescription);
    NopHtml.AddMetaKeywordParts(Model.MetaKeywords);
    //page class
    NopHtml.AppendPageCssClassParts("html-category-page");

    if (seoSettings.CanonicalUrlsEnabled)
    {
        var categoryUrl = Url.RouteUrl<Category>(new { SeName = Model.SeName }, webHelper.GetCurrentRequestProtocol()).ToLowerInvariant();
        NopHtml.AddCanonicalUrlParts(categoryUrl, seoSettings.QueryStringInCanonicalUrlsEnabled);
    }

    var breadcrumbDelimiter = commonSettings.BreadcrumbDelimiter;
}

@section CatalogFilters {
    @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsBeforeFilters, additionalData = Model })
    @await Html.PartialAsync("_CatalogFilters", Model.CatalogProductsModel)
}

<div class="page category-page">
    <div class="page-title">
        <h1>@Model.Name</h1>
        @if (Model.DisplayCategoryBreadcrumb)
        {
            <div class="breadcrumb">
                <ul>
                    <li>
                        <a href="@Url.RouteUrl("Homepage")" title="@T("Categories.Breadcrumb.Top")">@T("Categories.Breadcrumb.Top")</a>
                        <span class="delimiter">@breadcrumbDelimiter</span>
                    </li>
                    @{ int position = 1; }
                    @foreach (var cat in Model.CategoryBreadcrumb)
                    {
                        var isLastCategory = cat.Id == Model.Id;
                        <li>
                            @if (isLastCategory)
                            {
                                <strong class="current-item">@cat.Name</strong>
                                <span id="@(Url.RouteUrl<Category>(new { SeName = cat.SeName }))"></span>
                            }
                            else
                            {
                                <a href="@(Url.RouteUrl<Category>(new { SeName = cat.SeName }))" title="@cat.Name">
                                    <span>@cat.Name</span>
                                </a>
                                <span class="delimiter">@breadcrumbDelimiter</span>
                            }
                        </li>
                        position++;
                    }
                </ul>
                @if (seoSettings.MicrodataEnabled)
                {
                    <script type="application/ld+json">
                        @Html.Raw(Model.JsonLd)
                    </script>
                }
            </div>
            @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsAfterBreadcrumb, additionalData = Model })
        }
    </div>
    <div class="page-body">
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsTop, additionalData = Model })
        @*description*@
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="category-description">
                @Html.Raw(Model.Description)
            </div>
        }
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsBeforeSubcategories, additionalData = Model })
        @*subcategories*@
        @if (Model.SubCategories.Count > 0)
        {
            <div class="category-grid sub-category-grid">
                <div class="item-grid 2">
                    @foreach (var item in Model.SubCategories)
                    {
                        <div class="item-box">
                            <div class="sub-category-item">
                                <div class="picture">
                                    <a href="@(Url.RouteUrl<Category>(new { SeName = item.SeName }))" title="@item.PictureModel.Title">
                                        @if (viewComponentSelector.SelectComponent("LazyLoadImage") != null)
                                        {
                                            @await Component.InvokeAsync("LazyLoadImage", new(string Key, string Value)[]
                                            {
                                                ("src", item.PictureModel.ImageUrl),
                                                ("alt", item.PictureModel.AlternateText),
                                                ("title", item.PictureModel.Title)
                                            })
                                        }
                                        else
                                        {
                                            <img alt="@item.PictureModel.AlternateText" src="@item.PictureModel.ImageUrl" title="@item.PictureModel.Title" />
                                        }
                                    </a>
                                </div>
                                <div class="content-wrapper">
                                    <h2 class="title">
                                        <a href="@(Url.RouteUrl<Category>(new { SeName = item.SeName }))" title="@item.PictureModel.Title">
                                            @item.Name
                                        </a>
                                    </h2>

                                    @await Component.InvokeAsync("Widget", new { widgetZone = "prisma_itembox_subcategories", additionalData = item.Id })
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsBeforeFeaturedProducts, additionalData = Model })
        @*featured products*@
        @if (Model.FeaturedProducts.Count > 0)
        {
            <div class="product-grid featured-product-grid">
                <div class="title">
                    <strong>@T("Products.FeaturedProducts")</strong>
                </div>
                <div class="item-grid 1">
                    @foreach (var item in Model.FeaturedProducts)
                    {
                        <div class="item-box">
                            @await Html.PartialAsync("_ProductBox", item)
                        </div>
                    }
                </div>
            </div>
        }
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsAfterFeaturedProducts, additionalData = Model })
        @await Html.PartialAsync("_CatalogSelectors", Model.CatalogProductsModel)
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsBeforeProductList, additionalData = Model })
        @{
            var catalogProductsViewData = new ViewDataDictionary(ViewData);
            catalogProductsViewData["fetchUrl"] = Html.Raw(Url.RouteUrl("GetCategoryProducts", new { categoryId = Model.Id }));
        }
        @await Html.PartialAsync("_CatalogProducts", Model.CatalogProductsModel, catalogProductsViewData)
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.CategoryDetailsBottom, additionalData = Model })
    </div>
</div>
<style>
    .priceRangeMinMaxPanel {
        display: flex;
        gap: 10px; /* مسافة بين الـ Min و Max */
        align-items: center;
        margin: 10px 0;
    }

    .priceRangeMinPanel,
    .priceRangeMaxPanel {
        display: flex;
        align-items: center;
        gap: 5px; /* مسافة بين الـ label والـ input */
    }

    .priceInput {
        padding: 5px 8px;
        border: 1px solid #ccc;
        border-radius: 6px;
        width: 100%;
    }

    .inputslid button {
        background-color: #09426a !important;
        padding: 9px 14px;
        color: white;
        font-weight: bold;
        border-radius: 5px;
    }

    .inputslid {
        margin: 10px;
        text-align: center;
    }

    @@media (max-width: 1024px) {
        .block * {
            color: #000 !important;
            font-size: 15px !important;
        }

        button.searchfilterbut {
            color: white !important;
        }
    }
</style>


<script>
    $(document).ready(function () {
        setTimeout(function () {
            const $slider = $("#slider");
            const absoluteMin = parseInt($slider.data("sliderminvalue"));
            const absoluteMax = parseInt($slider.data("slidermaxvalue"));

            // استبدال الحقول بالـ placeholder
            $('.priceRangeMinPrice').replaceWith(`
                <input type="text"
                       class="priceInput minPrice"
                       placeholder="${absoluteMin}">
            `);
            $('.priceRangeMaxPrice').replaceWith(`
                <input type="text"
                       class="priceInput maxPrice"
                       placeholder="${absoluteMax}">
            `);

            // تهيئة السلايدر
            $slider.slider({
                range: true,
                min: absoluteMin,
                max: absoluteMax,
                values: [absoluteMin, absoluteMax],
                slide: function (e, ui) {
                    $(".minPrice").val(ui.values[0]);
                    $(".maxPrice").val(ui.values[1]);
                    updateDisplayedPrices(ui.values[0], ui.values[1]);
                    triggerPriceFilter();
                }
            });

            // تحديث السلايدر فقط أثناء الكتابة بدون فالدشن
            $(document).on('input', '.priceInput', function () {
                const $input = $(this);
                const rawValue = $input.val().trim();

                if (rawValue === "") {
                    $input.css('border', '2px solid orange');
                    return;
                }

                const parsedValue = parseInt(rawValue);
                const isMin = $input.hasClass('minPrice');

                let newMin, newMax;

                if (isMin) {
                    newMin = isNaN(parsedValue) ? absoluteMin : Math.max(absoluteMin, Math.min(parsedValue, absoluteMax));
                    newMax = parseInt($(".maxPrice").val() || absoluteMax);
                    if (newMin > newMax) newMax = newMin;
                } else {
                    newMax = isNaN(parsedValue) ? absoluteMax : Math.max(absoluteMin, Math.min(parsedValue, absoluteMax));
                    newMin = parseInt($(".minPrice").val() || absoluteMin);
                    if (newMax < newMin) newMin = newMax;
                }

                if (!isNaN(parsedValue)) {
                    $slider.slider("values", [newMin, newMax]);
                    updateDisplayedPrices(newMin, newMax);
                    $input.css('border', '1px solid #ccc');
                } else {
                    $input.css('border', '2px solid orange');
                }
            });

            // التحقق النهائي عند فقدان التركيز
            $(document).on('blur', '.priceInput', function () {
                validateAndUpdate(this);
            });

            function validateAndUpdate(input) {
                const $input = $(input);
                const isMin = $input.hasClass('minPrice');
                const rawVal = $input.val().trim();
                let value = parseInt(rawVal);

                if (isNaN(value)) {
                    $input.css('border', '2px solid red');
                    return;
                }

                if (isMin) {
                    value = Math.max(absoluteMin, Math.min(value, absoluteMax));
                    const currentMax = parseInt($(".maxPrice").val() || absoluteMax);
                    if (value > currentMax) $(".maxPrice").val(value);
                } else {
                    value = Math.min(absoluteMax, Math.max(value, absoluteMin));
                    const currentMin = parseInt($(".minPrice").val() || absoluteMin);
                    if (value < currentMin) $(".minPrice").val(value);
                }

                $input.val(value).css('border', '1px solid #ccc');

                const finalMin = parseInt($(".minPrice").val() || absoluteMin);
                const finalMax = parseInt($(".maxPrice").val() || absoluteMax);
                $slider.slider("values", [finalMin, finalMax]);
                updateDisplayedPrices(finalMin, finalMax);
                triggerPriceFilter();
            }

            function updateDisplayedPrices(min, max) {
                $(".currentMinPrice").text(formatNumber(min));
                $(".currentMaxPrice").text(formatNumber(max));
            }

            function formatNumber(num) {
                return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            }

            function triggerPriceFilter() {
                console.log("Filtering with:", {
                    min: $(".minPrice").val() || absoluteMin,
                    max: $(".maxPrice").val() || absoluteMax
                });
                // قم بإضافة استدعاء AJAX هنا
            }
        }, 10);
    });

    $(document).ready(function () {
        $(".searchfilterbut").on("click", function () {
            var slider = $("#slider");
            var min = parseFloat(slider.slider("option", "values")[0]);
            var max = parseFloat(slider.slider("option", "values")[1]);

            // تخزين القيم المختارة
            PriceRangeFilterManager.sliderSelectedFromValue = min;
            PriceRangeFilterManager.sliderSelectedToValue = max;

            // تشغيل طلب التصفية (زي ما السكربت الأصلي بيعمل)
            var filterManager = new FiltersManager();
            filterManager.requestProductsForSelectedFilters($(".priceRangeFilterPanel7Spikes"));
        });
    });
</script>





@*--------------------enter event*@
<script asp-location="Footer">
    window.onload = function () {
        // Get both input fields and the button
        const minPriceInput = document.querySelector('.priceInput.minPrice');
        const maxPriceInput = document.querySelector('.priceInput.maxPrice');
        const searchButton = document.querySelector('.searchfilterbut');

        // Function to handle Enter key press
        function handleEnterKey(event) {
            if (event.key === 'Enter') {
                searchButton.click();
            }
        }

        // Add event listener to both inputs
        minPriceInput.addEventListener('keypress', handleEnterKey);
        maxPriceInput.addEventListener('keypress', handleEnterKey);
    };
</script>




<script asp-location="Footer">
    window.onload = function () {
        if (window.innerWidth >= 768) { // 768 بكسل أو أكثر = ديسكتوب
            document.querySelectorAll('.priceInput.minPrice, .priceInput.maxPrice').forEach(function (input) {
                input.addEventListener('blur', function () {
                    setTimeout(function () {
                        document.querySelector('.searchfilterbut')?.click();
                    }, 1500);
                });
            });
        }
    };


</script>
