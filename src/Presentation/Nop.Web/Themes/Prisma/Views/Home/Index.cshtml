<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

    body {
        font-family: 'Inter', sans-serif;
    }

    .hero-bg {
        background-color: #1a237e;
        background-image: radial-gradient(circle at 10% 20%, rgba(255,255,255,0.05) 0%, transparent 20%), radial-gradient(circle at 90% 80%, rgba(255,255,255,0.05) 0%, transparent 20%);
    }

    .search-box {
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .category-card {
        transition: all 0.3s ease;
    }

        .category-card:hover {
            transform: translateY(-5px);
        }

    .brand-logo {
        filter: grayscale(100%);
        opacity: 0.5;
        transition: all 0.3s;
    }

        .brand-logo:hover {
            filter: grayscale(0%);
            opacity: 1;
        }
    html.html-home-page div#main {
        padding: 0
    }
       .container {
       display: grid;
       grid-template-columns: 280px repeat(3, 1fr);
       grid-template-rows: repeat(2, 1fr);
       gap: 20px;
       max-width: 1200px;
       width: 100%;
   }

   /* Base Card Style */
   .card {
       background: white;
       border-radius: var(--border-radius);
       overflow: hidden;
       display: flex;
       flex-direction: column;
       box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
       transition: transform 0.3s ease;
       cursor: pointer;
       position: relative;
   }

   .card:hover {
       transform: translateY(-5px);
   }

   /* Diagonal Stripes Pattern */
   .stripes-overlay {
       height: 180px;
       background: repeating-linear-gradient(
           45deg,
           #e5e7eb,
           #e5e7eb 10px,
           #f3f4f6 10px,
           #f3f4f6 20px
       );
       position: relative;
       display: flex;
       align-items: center;
       justify-content: center;
   }

   .stripes-overlay::after {
       content: '';
       position: absolute;
       top: 15px;
       right: 15px;
       width: 40px;
       height: 40px;
       border: 2px solid rgba(0, 0, 0, 0.1);
       border-radius: 50%;
       background: radial-gradient(circle, transparent 40%, rgba(0,0,0,0.05) 45%);
   }

   .placeholder-text {
       font-size: 10px;
       color: rgba(0, 0, 0, 0.3);
       text-transform: uppercase;
       letter-spacing: 1px;
       font-weight: bold;
       position: absolute;
       bottom: 10px;
   }

   /* Content Section */
   .card-content {
       padding: 20px;
       flex-grow: 1;
       display: flex;
       flex-direction: column;
       justify-content: space-between;
       position: relative;
   }

   .card-title {
       font-size: 18px;
       font-weight: 700;
       color: var(--dark-blue);
       margin: 0 0 5px 0;
   }

   .card-desc {
       font-size: 13px;
       color: var(--text-gray);
       margin-bottom: 20px;
   }

   .card-sku {
       font-size: 12px;
       color: #9ca3af;
       font-weight: 500;
   }

   .arrow-icon {
       position: absolute;
       top: 20px;
       right: 20px;
       color: var(--dark-blue);
       font-size: 18px;
   }

   /* Featured Tall Card (Bearings) */
   .card-featured {
       grid-row: span 2;
       background-color: var(--dark-blue);
       color: white;
   }

   .card-featured .stripes-overlay {
       height: 100%;
       background: repeating-linear-gradient(
           45deg,
           #0f172a,
           #0f172a 10px,
           #1e293b 10px,
           #1e293b 20px
       );
       flex-grow: 1;
   }

   .card-featured .card-content {
       background-color: var(--dark-blue);
       padding: 25px 20px;
       flex-grow: 0;
   }

   .card-featured .card-title,
   .card-featured .arrow-icon {
       color: white;
   }

   .card-featured .card-desc,
   .card-featured .card-sku {
       color: rgba(255, 255, 255, 0.7);
   }

   /* Yellowish Card Backgrounds */
   .bg-yellow {
       background-color: var(--light-yellow);
   }

   /* Responsive */
   @@media (max-width: 1024px) {
       .container {
           grid-template-columns: 1fr 1fr;
           grid-template-rows: auto;
       }
       .card-featured {
           grid-row: span 1;
           height: 400px;
       }
   }

   @@media (max-width: 600px) {
       .container {
           grid-template-columns: 1fr;
       }
   }
    section.py-20.bg-gray-50 {
        background-color: #f5f6fb !important;
    }
    .text-white {
        color: white !important
    }
    .card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .tab-button {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 12px;
        font-weight: 500;
    }

    .tab-active {
        background-color: #000833;
        color: white;
    }

    .tab-inactive {
        color: #6b7280;
    }

    .input-field {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 16px;
        width: 100%;
        color: #1e293b;
        font-weight: 500;
        outline: none;
        transition: border-color 0.2s;
    }

        .input-field:focus {
            border-color: #1e1b4b;
        }

    .label-text {
        color: #94a3b8;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
    }

    .label-unit {
        color: #cbd5e1;
        font-weight: 400;
        text-transform: lowercase;
    }

    .toggle-link {
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .toggle-active {
        color: #1e1b4b;
        border-bottom: 2px solid #eab308;
        padding-bottom: 2px;
    }

    .toggle-inactive {
        color: #94a3b8;
    }

    .search-btn {
        background-color: #1e1b4b;
        color: white;
        padding: 12px 32px;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 18px;
        transition: background-color 0.2s;
    }

        .search-btn:hover {
            background-color: #312e81;
        }

    .info-text {
        color: #94a3b8;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .hidden {
        display: none;
    }
</style>
@{
    Layout = "_ColumnsOne";

    var homepageTitle = await localizationService.GetLocalizedAsync(await storeContext.GetCurrentStoreAsync(), s => s.HomepageTitle);

    //title
    if (!string.IsNullOrEmpty(homepageTitle))
    {
        NopHtml.AddTitleParts(homepageTitle);
    }

    var homepageDescription = await localizationService.GetLocalizedAsync(await storeContext.GetCurrentStoreAsync(), s => s.HomepageDescription);

    //meta
    if (!string.IsNullOrEmpty(homepageDescription))
    {
        NopHtml.AddMetaDescriptionParts(homepageDescription);
    }

    //page class
    NopHtml.AppendPageCssClassParts("html-home-page");
}
