    .product-ribbon.limited-time-over label.ribbon-text {
        display: block !important;
    }
    tr.known td {
        color: #1f278a !important;
        font-weight: bold;
    }
    .similar-products-grid.product-list.f.similarknown .grid-item {
        color: #444;
        padding: 0;
        border: 0;
        text-align: left
    }
    .similar-products-grid .product-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;margin-top:0;
    }

    .similar-products-grid .grid-item {
        position: relative;
        padding: 8px 14px 8px 14px !important;
        background: #f8f9fa;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        color: #333;
        border: 1px solid #e5e5e5;
        transition: all 0.3s ease;
    }
    .similar-products-grid.product-list.f.similarknown {
        margin: 0 !important;
    }
        /* الدايرة */
